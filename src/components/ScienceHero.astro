---
import Button from "./Button.astro";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-20 md:pt-44 md:pb-24 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="max-w-2xl">
      <h1
        class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6 text-cream"
      >
        The science &amp; the system
      </h1>
      <p
        class="font-sans text-base sm:text-lg text-cream/70 mb-10 leading-relaxed max-w-xl"
      >
        Learn what quantum biology is and how we're building a new,
        decentralized process to fund its most important experiments.
      </p>
      <Button
        href="https://quantumbiology.community"
        variant="primary"
        size="md"
        external>Join the science working group</Button
      >
    </div>
  </div>
</section>
