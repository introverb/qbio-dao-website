---
const linkColumns = [
  {
    heading: "Explore",
    links: [
      { label: "Community", href: "/community" },
      { label: "Governance", href: "/qbio-token" },
      { label: "Token", href: "/qbio-token" },
      { label: "Science", href: "/science" },
    ],
  },
  {
    heading: "Get involved",
    links: [
      { label: "Buy QBIO", href: "/qbio-token#how-to-buy" },
      { label: "Join Discord", href: "https://quantumbiology.community" },
      { label: "Apply for a grant", href: "/science#granting" },
      { label: "FAQs", href: "/faqs" },
    ],
  },
];

const socials = [
  { label: "X (formerly Twitter)", href: "#", icon: "x" },
  { label: "LinkedIn", href: "#", icon: "linkedin" },
  { label: "YouTube", href: "#", icon: "youtube" },
  { label: "Bluesky", href: "#", icon: "bluesky" },
];
---

<footer class="bg-plum-darkest text-cream pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid md:grid-cols-12 gap-10 md:gap-16 mb-16">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 mb-6">
          <img
            src="/images/brand/logo-mark.png"
            alt=""
            width="48"
            height="48"
            class="w-12 h-12"
          />
          <span class="font-sans font-bold text-base leading-tight">
            Quantum Biology<br />DAO
          </span>
        </a>
        <p class="font-sans text-sm text-cream/60 max-w-xs leading-relaxed">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt.
        </p>
      </div>
      {
        linkColumns.map((col) => (
          <div class="md:col-span-2">
            <h3 class="font-sans text-xs uppercase tracking-[0.2em] text-cream/50 mb-4">
              {col.heading}
            </h3>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="font-sans text-sm text-cream/80 hover:text-cream transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <div class="md:col-span-4">
        <h3
          class="font-sans text-xs uppercase tracking-[0.2em] text-cream/50 mb-4"
        >
          Newsletter
        </h3>
        <p class="font-sans text-sm text-cream/70 mb-4">
          Lorem ipsum dolor sit amet, consectetur adipiscing.
        </p>
        <form class="flex flex-col sm:flex-row gap-3">
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            placeholder="you@example.com"
            class="flex-1 bg-plum-dark border border-cream/20 rounded-full px-5 py-2.5 font-sans text-sm text-cream placeholder-cream/40 focus:outline-none focus:border-pink"
          />
          <button
            type="submit"
            class="bg-pink text-plum-darkest rounded-full px-6 py-2.5 font-sans text-sm font-semibold hover:bg-pink-light transition-colors"
          >
            Subscribe
          </button>
        </form>
        <ul class="flex items-center gap-6 mt-8" aria-label="Social links">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  aria-label={s.label}
                  class="text-cream/80 hover:text-pink transition-colors block"
                >
                  {s.icon === "x" && (
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  )}
                  {s.icon === "linkedin" && (
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  )}
                  {s.icon === "youtube" && (
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                    </svg>
                  )}
                  {s.icon === "bluesky" && (
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="border-t border-cream/10 pt-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
    >
      <p class="font-sans text-xs text-cream/40">
        © {new Date().getFullYear()} Quantum Biology DAO. All rights reserved.
      </p>
      <ul class="flex gap-6 font-sans text-xs text-cream/40">
        <li>
          <a href="#" class="hover:text-cream transition-colors">Privacy</a>
        </li>
        <li>
          <a href="#" class="hover:text-cream transition-colors">Terms</a>
        </li>
      </ul>
    </div>
  </div>
</footer>
