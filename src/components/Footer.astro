---
const linkColumns = [
  {
    heading: "Explore",
    links: [
      { label: "Community", href: "#community" },
      { label: "Governance", href: "#governance" },
      { label: "Token", href: "#token" },
      { label: "Science", href: "#science" },
    ],
  },
  {
    heading: "Get involved",
    links: [
      { label: "Buy QBIO", href: "#" },
      { label: "Join Discord", href: "#" },
      { label: "Apply for a grant", href: "#" },
      { label: "FAQs", href: "#faqs" },
    ],
  },
];

const socials = [
  { label: "Twitter / X", href: "#", icon: "x" },
  { label: "Discord", href: "#", icon: "discord" },
  { label: "YouTube", href: "#", icon: "youtube" },
  { label: "Bluesky", href: "#", icon: "bluesky" },
  { label: "GitHub", href: "#", icon: "github" },
];
---

<footer class="bg-plum-darkest text-cream pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid md:grid-cols-12 gap-10 md:gap-16 mb-16">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 mb-6">
          <img
            src="/images/brand/logo-mark.png"
            alt=""
            width="48"
            height="48"
            class="w-12 h-12"
          />
          <span class="font-sans font-bold text-base leading-tight">
            Quantum Biology<br />DAO
          </span>
        </a>
        <p class="font-sans text-sm text-cream/60 max-w-xs leading-relaxed">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt.
        </p>
      </div>
      {
        linkColumns.map((col) => (
          <div class="md:col-span-2">
            <h3 class="font-sans text-xs uppercase tracking-[0.2em] text-cream/50 mb-4">
              {col.heading}
            </h3>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="font-sans text-sm text-cream/80 hover:text-cream transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <div class="md:col-span-4">
        <h3
          class="font-sans text-xs uppercase tracking-[0.2em] text-cream/50 mb-4"
        >
          Newsletter
        </h3>
        <p class="font-sans text-sm text-cream/70 mb-4">
          Lorem ipsum dolor sit amet, consectetur adipiscing.
        </p>
        <form class="flex flex-col sm:flex-row gap-3">
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            placeholder="you@example.com"
            class="flex-1 bg-plum-dark border border-cream/20 rounded-full px-5 py-2.5 font-sans text-sm text-cream placeholder-cream/40 focus:outline-none focus:border-pink"
          />
          <button
            type="submit"
            class="bg-pink text-plum-darkest rounded-full px-6 py-2.5 font-sans text-sm font-semibold hover:bg-pink-light transition-colors"
          >
            Subscribe
          </button>
        </form>
        <ul class="flex items-center gap-5 mt-8" aria-label="Social links">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  aria-label={s.label}
                  class="text-cream/60 hover:text-pink transition-colors block"
                >
                  {s.icon === "x" && (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  )}
                  {s.icon === "discord" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                    </svg>
                  )}
                  {s.icon === "youtube" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                    </svg>
                  )}
                  {s.icon === "bluesky" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.81 9.498 7.823 4.308 4.557-5.073 1.082-6.498-2.83-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z" />
                    </svg>
                  )}
                  {s.icon === "github" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="border-t border-cream/10 pt-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
    >
      <p class="font-sans text-xs text-cream/40">
        © {new Date().getFullYear()} Quantum Biology DAO. All rights reserved.
      </p>
      <ul class="flex gap-6 font-sans text-xs text-cream/40">
        <li>
          <a href="#" class="hover:text-cream transition-colors">Privacy</a>
        </li>
        <li>
          <a href="#" class="hover:text-cream transition-colors">Terms</a>
        </li>
      </ul>
    </div>
  </div>
</footer>
