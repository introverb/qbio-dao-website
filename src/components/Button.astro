---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline-light" | "outline-dark";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className = "",
} = Astro.props;

const variantClasses: Record<string, string> = {
  primary:
    "bg-pink text-plum-darkest hover:bg-pink-light",
  secondary:
    "bg-cream text-plum-darkest hover:bg-paper",
  "outline-light":
    "border border-cream/40 text-cream hover:border-cream hover:bg-cream/5",
  "outline-dark":
    "border border-plum-darkest/30 text-plum-darkest hover:border-plum-darkest hover:bg-plum-darkest/5",
};

const sizeClasses: Record<string, string> = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-2.5 text-sm",
  lg: "px-8 py-3.5 text-base",
};

const classes = [
  "inline-flex items-center gap-2 rounded-full font-sans font-semibold tracking-wide transition-colors duration-200 whitespace-nowrap",
  variantClasses[variant],
  sizeClasses[size],
  className,
]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a
      href={href}
      class={classes}
      {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
    >
      <slot />
      {external && (
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      )}
    </a>
  ) : (
    <button class={classes} type="button">
      <slot />
    </button>
  )
}
