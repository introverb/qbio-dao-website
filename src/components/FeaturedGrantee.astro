---
import Button from "./Button.astro";
---

<section class="bg-plum-dark text-cream py-16 md:py-20">
  <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
    <p
      class="font-sans text-xs tracking-[0.25em] uppercase text-pink mb-4"
    >
      Learn About Our
    </p>
    <h2 class="font-display text-3xl md:text-4xl mb-6">Featured Grantee</h2>
    <p
      class="font-sans text-cream/70 text-base md:text-lg max-w-2xl mx-auto mb-8 leading-relaxed"
    >
      We are engaging researchers, crypto enthusiasts, industry experts, and the
      general public to accelerate the quantum biology revolution.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <Button
        href="https://quantumbiology.org"
        variant="outline-light"
        external
      >
        The Quantum Biology Institute
      </Button>
      <Button href="/science#granting" variant="outline-light">
        Learn About Our Granting Process
      </Button>
    </div>
  </div>
</section>
