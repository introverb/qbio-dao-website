---
import Button from "./Button.astro";
---

<section class="bg-plum-darkest text-cream py-20 md:py-24">
  <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
    <h2 class="font-display text-3xl md:text-4xl mb-4">
      Ready to Shape the Future of Quantum Biology?
    </h2>
    <p class="font-sans text-base text-cream/75 mb-10 max-w-2xl mx-auto">
      Buy QBIO or connect with our community to start participating today.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button
        href="https://quantumbiology.community"
        variant="outline-light"
        size="md"
        external>Join the Discord</Button
      >
      <Button href="#how-to-buy" variant="outline-light" size="md">Buy QBIO</Button>
    </div>
  </div>
</section>
