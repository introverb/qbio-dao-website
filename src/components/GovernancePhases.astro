---
const phases = [
  {
    number: 1,
    title: "Drafting",
    duration: "Varies",
    tool: "Discord",
    icon: "draft",
    body: "New proposals are introduced in the governance-proposal channel on Discord, where early-stage ideas are shared and discussed. Proposals may be made by any Quantum Biology DAO community member, including members of the Quantum Biology DAO team. Proposals in this phase are flexible in format and designed to promote open dialogue. A proposal advances to Phase 2 if it receives a minimum of five upvotes, with at least two from Quantum Biology DAO Core Contributors.",
  },
  {
    number: 2,
    title: "Community Voting",
    duration: "1/3/7 Days",
    tool: "Commonwealth",
    icon: "community",
    body: "Proposals that pass Phase 1 advance to Common for further discussion and community voting. Voting in Phase 2 requires participants to hold at least 10,000 QBIO, the DAO's governance token. If, by the end of the discussion period, a proposal gets ten or more votes with a majority in favor, it moves to the final stage, Phase 3. Otherwise, it returns to Phase 1 discussion on Discord or is dropped.",
  },
  {
    number: 3,
    title: "Token Voting",
    duration: "1/3/7 Days",
    tool: "Snapshot",
    icon: "token",
    body: "Final-stage voting is open to all holders of the DAO's governance token. Token holders may assign their voting power to a delegate of their choice from within the community. Proposals must meet a 3% quorum and a simple majority of total votes in favor to pass. A proposal is considered unsuccessful if it does not achieve either the required quorum or simple majority in favor. The Association reserves the right to act before the voting period concludes if the outcome is decisively clear.",
  },
];
---

<section class="bg-plum-darkest text-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2 class="font-display text-3xl md:text-4xl mb-4">
      How governance works: 3 simple phases
    </h2>
    <p
      class="max-w-3xl font-sans text-base text-cream/80 leading-relaxed mb-14"
    >
      The Quantum Biology DAO governance process is structured into three
      progressive phases, each designed to guide proposals from ideation to
      implementation.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        phases.map((p) => (
          <div class="flex flex-col">
            <div class="relative aspect-[3/2] rounded-3xl bg-mauve/40 border border-cream/10 flex items-center justify-center mb-6 shadow-xl text-cream overflow-hidden hex-bg">
              {p.icon === "draft" && (
                <svg
                  class="relative"
                  width="160"
                  height="160"
                  viewBox="0 0 64 64"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  {/* Hexagonal speech bubble — discussion starting on Discord */}
                  <path d="M14 12 L50 12 Q54 12 54 16 L54 40 Q54 44 50 44 L36 44 L28 52 L28 44 L14 44 Q10 44 10 40 L10 16 Q10 12 14 12 Z" />
                  <circle cx="24" cy="28" r="1.6" fill="currentColor" stroke="none" />
                  <circle cx="32" cy="28" r="1.6" fill="currentColor" stroke="none" />
                  <circle cx="40" cy="28" r="1.6" fill="currentColor" stroke="none" />
                </svg>
              )}
              {p.icon === "community" && (
                <svg
                  class="relative"
                  width="160"
                  height="160"
                  viewBox="0 0 64 64"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  {/* Three connected hexagons — community of voters */}
                  <polygon points="32,6 42,12 42,24 32,30 22,24 22,12" />
                  <polygon points="16,30 26,36 26,48 16,54 6,48 6,36" />
                  <polygon points="48,30 58,36 58,48 48,54 38,48 38,36" />
                  <line x1="27" y1="27" x2="21" y2="33" />
                  <line x1="37" y1="27" x2="43" y2="33" />
                </svg>
              )}
              {p.icon === "token" && (
                <svg
                  class="relative"
                  width="160"
                  height="160"
                  viewBox="0 0 64 64"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  {/* QBIO-style hexagonal token with an internal check */}
                  <polygon points="32,6 54,18 54,46 32,58 10,46 10,18" />
                  <polygon
                    points="32,15 46,23 46,41 32,49 18,41 18,23"
                    stroke-opacity="0.35"
                  />
                  <polyline points="24,32 30,38 41,26" />
                </svg>
              )}
            </div>
            <div class="mb-4 space-y-1 font-sans">
              <p class="font-bold text-lg text-cream">
                Phase {p.number}: {p.title}
              </p>
              <p class="text-sm text-cream/80">Duration: {p.duration}</p>
              <p class="text-sm text-cream/80">Tool: {p.tool}</p>
            </div>
            <p class="font-sans text-sm text-cream/70 leading-relaxed">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Tessellating honeycomb hex pattern as a subtle background on the
     phase panels. The data-URI SVG draws one flat-top hexagon centered
     in a tile sized to its row/column repeat so the tiling reads as a
     continuous honeycomb. */
  .hex-bg {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='42' height='73' viewBox='0 0 42 73'><path d='M21 13.875 L40.5 25.125 L40.5 47.625 L21 58.875 L1.5 47.625 L1.5 25.125 Z' fill='none' stroke='%23eee8df' stroke-width='1.2' stroke-opacity='0.18'/></svg>");
    background-size: 42px 73px;
    background-position: center;
    background-repeat: repeat;
  }
</style>
