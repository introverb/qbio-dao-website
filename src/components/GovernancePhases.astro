---
const phases = [
  {
    number: 1,
    title: "Drafting",
    duration: "Varies",
    tool: "Discord",
    body: "New proposals are introduced in the governance-proposal channel on Discord, where early-stage ideas are shared and discussed. Proposals may be made by any Quantum Biology DAO community member, including members of the Quantum Biology DAO team. Proposals in this phase are flexible in format and designed to promote open dialogue. A proposal advances to Phase 2 if it receives a minimum of five upvotes, with at least two from Quantum Biology DAO Core Contributors.",
  },
  {
    number: 2,
    title: "Community Voting",
    duration: "1/3/7 Days",
    tool: "Commonwealth",
    body: "Proposals that pass Phase 1 advance to Common for further discussion and community voting. Voting in Phase 2 requires participants to hold at least 10,000 QBIO, the DAO's governance token. If, by the end of the discussion period, a proposal gets ten or more votes with a majority in favor, it moves to the final stage, Phase 3. Otherwise, it returns to Phase 1 discussion on Discord or is dropped.",
  },
  {
    number: 3,
    title: "Token Voting",
    duration: "1/3/7 Days",
    tool: "Snapshot",
    body: "Final-stage voting is open to all holders of the DAO's governance token. Token holders may assign their voting power to a delegate of their choice from within the community. Proposals must meet a 3% quorum and a simple majority of total votes in favor to pass. A proposal is considered unsuccessful if it does not achieve either the required quorum or simple majority in favor. The Association reserves the right to act before the voting period concludes if the outcome is decisively clear.",
  },
];
---

<section class="bg-plum-darkest text-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2 class="font-display text-3xl md:text-4xl mb-4">
      How governance works: 3 simple phases
    </h2>
    <p
      class="max-w-3xl font-sans text-base text-cream/80 leading-relaxed mb-14"
    >
      The Quantum Biology DAO governance process is structured into three
      progressive phases, each designed to guide proposals from ideation to
      implementation.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        phases.map((p) => (
          <div class="flex flex-col">
            <div class="aspect-[3/2] rounded-3xl bg-mauve/40 border border-cream/10 flex items-center justify-center mb-6 shadow-xl">
              <span class="font-display text-7xl md:text-8xl text-cream">
                {p.number}
              </span>
            </div>
            <div class="mb-4 space-y-1 font-sans">
              <p class="font-bold text-lg text-cream">
                Phase {p.number}: {p.title}
              </p>
              <p class="text-sm text-cream/80">Duration: {p.duration}</p>
              <p class="text-sm text-cream/80">Tool: {p.tool}</p>
            </div>
            <p class="font-sans text-sm text-cream/70 leading-relaxed">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
