---
const reasons = [
  {
    title: "You can vote on real scientific decisions",
    body: "Each QBIO token represents a vote. When you hold QBIO, you help decide which research we support and which tools we develop.",
    icon: "vote",
  },
  {
    title: "You support decentralized science",
    body: "QBIO helps create an open, transparent system for conducting science. This makes research more accessible and less dependent on institutions with narrow priorities.",
    icon: "network",
  },
  {
    title: "You contribute to building shared scientific infrastructure",
    body: "QBIO holders help fund new technologies, experiments, and open tools that benefit the entire ecosystem and beyond.",
    icon: "blocks",
  },
];
---

<section
  id="what-is-qbio"
  class="bg-plum-darkest text-cream py-20 md:py-28"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2 class="font-display text-3xl md:text-4xl mb-8 max-w-3xl">
      What are tokens? What is the QBIO token?
    </h2>
    <div
      class="max-w-3xl space-y-5 font-sans text-base text-cream/80 leading-relaxed mb-20"
    >
      <p>
        A token is a digital asset that allows people to participate in a
        decentralized system. In our case, the QBIO token is a governance token
        of the Quantum Biology DAO.
      </p>
      <p>
        Holding QBIO means you are part of the decision-making process: you can
        propose ideas, vote on proposals, and help shape the DAO's activities,
        including funding research, managing community initiatives, and setting
        strategic priorities.
      </p>
      <p>
        By participating, QBIO holders collectively advance quantum biology as
        an open, community-led field.
      </p>
    </div>

    <h2 class="font-display text-3xl md:text-4xl mb-12">
      Why should I buy QBIO?
    </h2>
    <div class="space-y-10">
      {
        reasons.map((r, i) => (
          <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6 md:gap-10 items-center">
            <div class="aspect-[3/2] rounded-2xl border border-cream/15 bg-plum-dark/30 flex items-center justify-center text-cream/70">
              {r.icon === "vote" && (
                <svg
                  width="56"
                  height="56"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M9 12l2 2 4-4" />
                  <path d="M21 12c0 5-3.5 7.5-9 7.5S3 17 3 12s3.5-7.5 9-7.5 9 2.5 9 7.5z" />
                </svg>
              )}
              {r.icon === "network" && (
                <svg
                  width="56"
                  height="56"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="5" r="2" />
                  <circle cx="5" cy="19" r="2" />
                  <circle cx="19" cy="19" r="2" />
                  <circle cx="12" cy="13" r="2" />
                  <path d="M12 7v4" />
                  <path d="M6.5 17.5l4-2.5" />
                  <path d="M17.5 17.5l-4-2.5" />
                </svg>
              )}
              {r.icon === "blocks" && (
                <svg
                  width="56"
                  height="56"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="3" y="3" width="8" height="8" rx="1" />
                  <rect x="13" y="3" width="8" height="8" rx="1" />
                  <rect x="3" y="13" width="8" height="8" rx="1" />
                  <rect x="13" y="13" width="8" height="8" rx="1" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-display text-xl md:text-2xl text-cream mb-3">
                {i + 1}. {r.title}
              </h3>
              <p class="font-sans text-sm md:text-base text-cream/75 leading-relaxed max-w-2xl">
                {r.body}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
