---
type Block =
  | { kind: "p"; text: string }
  | { kind: "ul"; items: string[] };

interface FAQ {
  question: string;
  body: Block[];
}

const faqs: FAQ[] = [
  {
    question: "What is a DAO",
    body: [
      {
        kind: "p",
        text: 'The word "DAO" means "decentralized autonomous organization." A DAO harnesses the collective efforts of many groups of contributors to expedite the development of innovations and new technologies. By using blockchain, our community can govern itself fairly and transparently, while also engaging a diverse and global pool of talent and contribution. Science DAOs fund and incubate projects from the initial stages of research. They stand out as community-owned and -operated entities.',
      },
    ],
  },
  {
    question: "Why should I get involved?",
    body: [
      {
        kind: "p",
        text: "To advance the field of quantum biology! By participating in the quantum biology DAO, you not only accelerate a new field of science, but earn the right to direct and govern our collective—shaping the arc of this new field.",
      },
    ],
  },
  {
    question: "Why does quantum biology matter?",
    body: [
      {
        kind: "p",
        text: "Quantum biology unlocks a fundamentally new way to actuate on biology. Check out how quantum biology overlaps with a wide array of fields in our briefs.",
      },
    ],
  },
  {
    question: "How can I get involved?",
    body: [
      {
        kind: "p",
        text: "We are excited to bring on new researchers to perform key experiments, community members to discuss the latest developments and suggest new avenues, advocates interested in spreading the word, and enthusiasts to direct our pool of resources into the most important research.",
      },
    ],
  },
  {
    question: "Who can join the DAO? Do I need to be a scientist to participate?",
    body: [
      {
        kind: "p",
        text: "Anyone can join the Quantum Biology DAO. You do not need to be a scientist to participate. The DAO brings together researchers, creatives, engineers, builders, writers, funders, organizers, and curious community members who want to help advance the field. Scientific expertise is essential to our mission, but progress also depends on governance, funding decisions, communications, education, and community coordination. Different contributors add value in different ways.",
      },
    ],
  },
  {
    question: "What is the Quantum Biology Ecosystem?",
    body: [
      {
        kind: "p",
        text: "The Quantum Biology Ecosystem is a coordinated group of organizations working together to advance quantum biology from basic science to real-world impact.",
      },
      { kind: "p", text: "It includes:" },
      {
        kind: "ul",
        items: [
          "The Quantum Biology Institute, a nonprofit focused on foundational, open scientific research",
          "The Quantum Biology DAO (us!), a decentralized community that funds research, governs priorities, and supports translation and education",
          "The Quantum Biology Incubator (to be launched), which helps develop talent and early-stage ventures emerging from the field",
        ],
      },
      {
        kind: "p",
        text: "Together, these entities align incentives across research, funding, governance, and commercialization to accelerate the development of quantum biology as a scientific field and future industry.",
      },
    ],
  },
  {
    question: "What is quantum biology?",
    body: [
      {
        kind: "p",
        text: 'Quantum biology is an emerging scientific field which asks: "How does life depend on quantum phenomena?" Working at the intersection of quantum physics and biology, the field studies how quantum phenomena, which are tiny and ubiquitous, impact biological systems, including the development and functioning of the human body. These quantum phenomena include electron spin superpositions, noise-assisted tunneling, and more.',
      },
    ],
  },
  {
    question: "Why is quantum biology important?",
    body: [
      {
        kind: "p",
        text: "Physics has produced extensive knowledge of the universe on a fundamental level. Biology, however, remains, to an important extent, a mystery. Quantum biology is building a bridge between the fields, making it possible to explain phenomena that have never been explained before, like the biological effects of weak magnetic fields. Understanding how quantum phenomena shape the life of the cell will unlock a new level of biological understanding, which may yield many applications in health, biomanufacturing, and beyond.",
      },
    ],
  },
  {
    question: "How does classical biology compare to quantum biology?",
    body: [
      {
        kind: "p",
        text: "Classical biology studies life under the assumption that matter behaves classically, that is, as described by the physical laws of Newton and electromagnetic laws of Maxwell. Quantum biology adds the equations developed by Schrödinger and Dirac, which yield different predictions about the behavior of atoms, molecules, weak magnetic fields, and more.",
      },
    ],
  },
  {
    question: "How can I help advance the quantum biology community?",
    body: [
      {
        kind: "p",
        text: "We are excited to bring on new researchers to perform key experiments, community members to discuss the latest developments and suggest new avenues, advocates interested in spreading the word, and enthusiasts to direct our pool of resources into the most important research.",
      },
    ],
  },
];
---

<section
  class="bg-plum-darkest text-cream py-16 md:py-24 border-t border-cream/15"
>
  <div class="max-w-4xl mx-auto px-6 lg:px-12">
    <div
      class="space-y-5 font-sans text-base text-cream/80 leading-relaxed mb-14"
    >
      <p>
        Quantum Biology DAO exists to fund and coordinate open research into
        quantum biology, a field that explores how quantum phenomena like spin,
        superposition, or tunneling might influence living systems. We believe
        that the next breakthroughs in biology won't come from behind closed
        doors, but from the open collaboration of scientists, engineers, and
        curious people around the world.
      </p>
      <p>
        The DAO is part of a broader ecosystem that also includes the Quantum
        Biology Institute, a physical lab where experiments are being built,
        and the Quantum Biology Incubator, which supports early-stage ideas and
        tools.
      </p>
      <p>
        Below, you'll find answers to the most frequently asked questions about
        our governance model, the science behind our mission, and the roadmap
        ahead. If something's missing or unclear, reach out on Discord or to
        (email?). We're building this DAO in public, and we'd love your input.
      </p>
    </div>

    <div class="space-y-3">
      {
        faqs.map((f) => (
          <details class="faq-item group rounded-2xl bg-mauve/30 border border-cream/15 overflow-hidden transition-colors hover:bg-mauve/40">
            <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between gap-4 font-sans text-base md:text-lg text-cream font-medium">
              <span>{f.question}</span>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 text-cream/70 transition-transform duration-200 group-open:rotate-180"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="px-6 pb-6 pt-1 font-sans text-base text-cream/80 leading-relaxed space-y-3">
              {f.body.map((block) =>
                block.kind === "p" ? (
                  <p>{block.text}</p>
                ) : (
                  <ul class="list-disc pl-6 space-y-1.5">
                    {block.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                ),
              )}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  details.faq-item > summary::-webkit-details-marker {
    display: none;
  }
  details.faq-item > summary::marker {
    content: "";
  }
</style>
