---
import Button from "./Button.astro";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-20 md:pt-44 md:pb-28 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative z-10 max-w-xl">
        <h1
          class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6 text-cream"
        >
          How we make decisions together to advance quantum biology
        </h1>
        <div
          class="font-sans text-base sm:text-lg text-cream/70 leading-relaxed space-y-5 mb-10"
        >
          <p>
            Quantum Biology DAO is a decentralized organization that supports
            open scientific research at the frontier of biology and physics. We
            support experiments, technologies, and ideas that explore how
            quantum physics may influence living systems.
          </p>
          <p>
            Instead of relying on a central leader or institution, decisions are
            made collectively. Through transparent governance and shared digital
            tools, our community directs funding, sets priorities, and helps
            shape the future of quantum biology research.
          </p>
          <p>
            At the center of this process is QBIO, the governance token that
            powers the DAO.
          </p>
        </div>
        <Button href="#what-is-qbio" variant="primary" size="md"
          >Learn about QBIO</Button
        >
      </div>
      <div class="relative">
        <div
          id="qbio-coin-3d"
          class="w-full max-w-md mx-auto aspect-square"
          role="img"
          aria-label="3D rendering of the QBIO governance token, slowly spinning"
        ></div>
        <noscript>
          <img
            src="/images/graphics/coin.png"
            alt="QBIO governance token"
            class="w-full h-auto max-w-md mx-auto"
          />
        </noscript>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  const mount = document.getElementById("qbio-coin-3d");
  if (mount) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 100);
    camera.position.set(0, 0, 9);

    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const resize = () => {
      const size = Math.min(mount.clientWidth, 520);
      renderer.setSize(size, size, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    };
    resize();
    mount.appendChild(renderer.domElement);

    // Round coin geometry — 96 segments around for a clean curved rim.
    const radius = 2;
    const thickness = 0.4;
    const radialSegments = 96;
    const geometry = new THREE.CylinderGeometry(
      radius,
      radius,
      thickness,
      radialSegments,
    );

    // Soft warm environment so the metal has something to reflect.
    const envCanvas = document.createElement("canvas");
    envCanvas.width = 1024;
    envCanvas.height = 512;
    const ectx = envCanvas.getContext("2d")!;
    const envGrad = ectx.createLinearGradient(0, 0, 0, 512);
    envGrad.addColorStop(0.0, "#fff1e0");
    envGrad.addColorStop(0.45, "#e8c8de");
    envGrad.addColorStop(0.55, "#9d6da0");
    envGrad.addColorStop(1.0, "#241038");
    ectx.fillStyle = envGrad;
    ectx.fillRect(0, 0, 1024, 512);

    const envSource = new THREE.CanvasTexture(envCanvas);
    envSource.mapping = THREE.EquirectangularReflectionMapping;
    envSource.colorSpace = THREE.SRGBColorSpace;

    const pmrem = new THREE.PMREMGenerator(renderer);
    const envRenderTarget = pmrem.fromEquirectangular(envSource);
    scene.environment = envRenderTarget.texture;
    envSource.dispose();
    pmrem.dispose();

    // The face needs a custom-composited bump map: a raised outer ring
    // PLUS the logo glyph raised against a recessed inner field. We build
    // it on a canvas from the logo-mark image.
    const FACE_SIZE = 1024;
    const faceBumpCanvas = document.createElement("canvas");
    faceBumpCanvas.width = FACE_SIZE;
    faceBumpCanvas.height = FACE_SIZE;
    const fbctx = faceBumpCanvas.getContext("2d")!;
    // Black base = fully RECESSED field. White = fully RAISED.
    // Using the full black-to-white range gives the bump map its strongest
    // possible effect.
    fbctx.fillStyle = "#000000";
    fbctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    // Raised outer rim band
    fbctx.fillStyle = "#ffffff";
    fbctx.beginPath();
    fbctx.arc(FACE_SIZE / 2, FACE_SIZE / 2, FACE_SIZE * 0.495, 0, Math.PI * 2);
    fbctx.arc(
      FACE_SIZE / 2,
      FACE_SIZE / 2,
      FACE_SIZE * 0.43,
      0,
      Math.PI * 2,
      true,
    );
    fbctx.fill("evenodd");

    const faceBumpTexture = new THREE.CanvasTexture(faceBumpCanvas);
    faceBumpTexture.anisotropy = 8;
    // Mirror the texture horizontally — CylinderGeometry's top cap UVs
    // come out flipped relative to how we view the coin face.
    faceBumpTexture.wrapS = THREE.RepeatWrapping;
    faceBumpTexture.repeat.x = -1;
    faceBumpTexture.offset.x = 1;

    // Composite the logo on top once the image loads. We threshold the
    // logo image so bright pixels become white (raised) and the rest is
    // transparent (leaves the gray field underneath).
    const logoImg = new Image();
    logoImg.crossOrigin = "anonymous";
    logoImg.onload = () => {
      const off = document.createElement("canvas");
      off.width = logoImg.naturalWidth;
      off.height = logoImg.naturalHeight;
      const octx = off.getContext("2d")!;
      octx.drawImage(logoImg, 0, 0);
      const id = octx.getImageData(0, 0, off.width, off.height);
      const d = id.data;
      for (let i = 0; i < d.length; i += 4) {
        const brightness = (d[i] + d[i + 1] + d[i + 2]) / 3;
        if (brightness > 70) {
          d[i] = 255;
          d[i + 1] = 255;
          d[i + 2] = 255;
          d[i + 3] = 255;
        } else {
          d[i + 3] = 0;
        }
      }
      octx.putImageData(id, 0, 0);
      // Composite logo at center, sized to sit inside the raised rim
      const logoSize = FACE_SIZE * 0.72;
      const logoXY = (FACE_SIZE - logoSize) / 2;
      fbctx.drawImage(off, logoXY, logoXY, logoSize, logoSize);
      faceBumpTexture.needsUpdate = true;
    };
    logoImg.src = "/images/brand/logo-mark.png";

    // Two-tone color map: dark recessed field, lighter pink raised rim
    // and logo. Same canvas geometry as the bump map, just colored.
    const faceColorCanvas = document.createElement("canvas");
    faceColorCanvas.width = FACE_SIZE;
    faceColorCanvas.height = FACE_SIZE;
    const fcctx = faceColorCanvas.getContext("2d")!;
    const RECESSED = "#2c1843"; // deep purple field
    const RAISED = "#a878ba"; // lighter mauve-pink raised
    fcctx.fillStyle = RECESSED;
    fcctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    fcctx.fillStyle = RAISED;
    fcctx.beginPath();
    fcctx.arc(FACE_SIZE / 2, FACE_SIZE / 2, FACE_SIZE * 0.495, 0, Math.PI * 2);
    fcctx.arc(
      FACE_SIZE / 2,
      FACE_SIZE / 2,
      FACE_SIZE * 0.43,
      0,
      Math.PI * 2,
      true,
    );
    fcctx.fill("evenodd");

    const faceColorTexture = new THREE.CanvasTexture(faceColorCanvas);
    faceColorTexture.colorSpace = THREE.SRGBColorSpace;
    faceColorTexture.anisotropy = 8;
    // Match the bump map's horizontal flip so color and bump stay aligned.
    faceColorTexture.wrapS = THREE.RepeatWrapping;
    faceColorTexture.repeat.x = -1;
    faceColorTexture.offset.x = 1;

    const logoColorImg = new Image();
    logoColorImg.crossOrigin = "anonymous";
    logoColorImg.onload = () => {
      const off = document.createElement("canvas");
      off.width = logoColorImg.naturalWidth;
      off.height = logoColorImg.naturalHeight;
      const octx = off.getContext("2d")!;
      octx.drawImage(logoColorImg, 0, 0);
      const id = octx.getImageData(0, 0, off.width, off.height);
      const d = id.data;
      // Pre-parse the raised color into RGB
      const rr = parseInt(RAISED.slice(1, 3), 16);
      const gg = parseInt(RAISED.slice(3, 5), 16);
      const bb = parseInt(RAISED.slice(5, 7), 16);
      for (let i = 0; i < d.length; i += 4) {
        const brightness = (d[i] + d[i + 1] + d[i + 2]) / 3;
        if (brightness > 70) {
          d[i] = rr;
          d[i + 1] = gg;
          d[i + 2] = bb;
          d[i + 3] = 255;
        } else {
          d[i + 3] = 0;
        }
      }
      octx.putImageData(id, 0, 0);
      const logoSize = FACE_SIZE * 0.72;
      const logoXY = (FACE_SIZE - logoSize) / 2;
      fcctx.drawImage(off, logoXY, logoXY, logoSize, logoSize);
      faceColorTexture.needsUpdate = true;
    };
    logoColorImg.src = "/images/brand/logo-mark.png";

    const faceMaterial = new THREE.MeshStandardMaterial({
      map: faceColorTexture,
      bumpMap: faceBumpTexture,
      bumpScale: 2.0, // very bold relief
      metalness: 0.35,
      roughness: 0.55,
    });

    // Edge: procedurally drawn reeded grooves wrapped around the rim.
    const grooveCount = 160;
    const grooveCanvas = document.createElement("canvas");
    grooveCanvas.width = grooveCount * 4;
    grooveCanvas.height = 32;
    const gctx = grooveCanvas.getContext("2d")!;
    gctx.fillStyle = "#3a1f5a"; // matches the body
    gctx.fillRect(0, 0, grooveCanvas.width, grooveCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * grooveCanvas.width;
      gctx.fillStyle = "#6b3eaa"; // highlight ridge
      gctx.fillRect(x, 0, 2, grooveCanvas.height);
      gctx.fillStyle = "#180828"; // shadow groove
      gctx.fillRect(x + 2, 0, 2, grooveCanvas.height);
    }
    const grooveTexture = new THREE.CanvasTexture(grooveCanvas);
    grooveTexture.colorSpace = THREE.SRGBColorSpace;
    grooveTexture.wrapS = THREE.RepeatWrapping;
    grooveTexture.wrapT = THREE.ClampToEdgeWrapping;
    grooveTexture.anisotropy = 8;

    // Bump map for the edge — grayscale stripes
    const bumpCanvas = document.createElement("canvas");
    bumpCanvas.width = grooveCount * 4;
    bumpCanvas.height = 32;
    const bctx = bumpCanvas.getContext("2d")!;
    bctx.fillStyle = "#808080";
    bctx.fillRect(0, 0, bumpCanvas.width, bumpCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * bumpCanvas.width;
      bctx.fillStyle = "#ffffff";
      bctx.fillRect(x, 0, 2, bumpCanvas.height);
      bctx.fillStyle = "#000000";
      bctx.fillRect(x + 2, 0, 2, bumpCanvas.height);
    }
    const grooveBump = new THREE.CanvasTexture(bumpCanvas);
    grooveBump.wrapS = THREE.RepeatWrapping;
    grooveBump.wrapT = THREE.ClampToEdgeWrapping;

    const edgeMaterial = new THREE.MeshStandardMaterial({
      map: grooveTexture,
      bumpMap: grooveBump,
      bumpScale: 0.18,
      metalness: 0.35,
      roughness: 0.5,
    });

    // CylinderGeometry materials order: [side, top, bottom]
    const coin = new THREE.Mesh(geometry, [
      edgeMaterial,
      faceMaterial,
      faceMaterial,
    ]);

    // Group lets us spin around world Y regardless of coin's tilt
    const group = new THREE.Group();
    group.add(coin);
    // Tip the cylinder so its faces look at the camera
    coin.rotation.x = Math.PI / 2;
    // Subtle forward tilt so it doesn't go fully edge-on at 90°
    group.rotation.x = -0.18;
    scene.add(group);

    // Lighting — directional lights now do most of the work, so the deep
    // bumps cast strong shadows in the recessed areas.
    const ambient = new THREE.AmbientLight(0xffffff, 0.35);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xfff1e0, 1.4);
    keyLight.position.set(3, 4, 5);
    scene.add(keyLight);

    const rimLight = new THREE.DirectionalLight(0xd57db2, 0.6);
    rimLight.position.set(-4, -1, -3);
    scene.add(rimLight);

    const fillLight = new THREE.DirectionalLight(0x8855aa, 0.35);
    fillLight.position.set(2, -3, 4);
    scene.add(fillLight);

    // Animation
    const speed = 0.005;
    const animate = () => {
      if (!reducedMotion) {
        group.rotation.y += speed;
      }
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();

    // Respond to container resizing
    const ro = new ResizeObserver(resize);
    ro.observe(mount);
  }
</script>
