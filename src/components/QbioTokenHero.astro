---
import Button from "./Button.astro";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-20 md:pt-44 md:pb-28 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative z-10 max-w-xl">
        <h1
          class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6 text-cream"
        >
          How we make decisions together to advance quantum biology
        </h1>
        <div
          class="font-sans text-base sm:text-lg text-cream/70 leading-relaxed space-y-5 mb-10"
        >
          <p>
            Quantum Biology DAO is a decentralized organization that supports
            open scientific research at the frontier of biology and physics. We
            support experiments, technologies, and ideas that explore how
            quantum physics may influence living systems.
          </p>
          <p>
            Instead of relying on a central leader or institution, decisions are
            made collectively. Through transparent governance and shared digital
            tools, our community directs funding, sets priorities, and helps
            shape the future of quantum biology research.
          </p>
          <p>
            At the center of this process is QBIO, the governance token that
            powers the DAO.
          </p>
        </div>
        <Button href="#what-is-qbio" variant="primary" size="md"
          >Learn about QBIO</Button
        >
      </div>
      <div class="relative">
        <div
          id="qbio-coin-3d"
          class="w-full max-w-md mx-auto aspect-square"
          role="img"
          aria-label="3D rendering of the QBIO governance token, slowly spinning"
        ></div>
        <noscript>
          <img
            src="/images/graphics/coin.png"
            alt="QBIO governance token"
            class="w-full h-auto max-w-md mx-auto"
          />
        </noscript>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  console.log("[coin v6] script start — fresh build with displacement");

  const mount = document.getElementById("qbio-coin-3d");
  if (mount) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // ====== Scene + Camera + Renderer ======================================
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 100);
    camera.position.set(0, 0, 9);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const resize = () => {
      const size = Math.min(mount.clientWidth, 520);
      renderer.setSize(size, size, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    };
    resize();
    mount.appendChild(renderer.domElement);

    // ====== Coin dimensions ================================================
    const RADIUS = 2;
    const THICKNESS = 0.4;
    const FACE_SIZE = 512;

    // ====== Custom subdivided disc geometry ================================
    // Triangulates a flat circle with concentric rings so displacement
    // mapping has actual vertex density to push around.
    function createDisc(radius: number, rings: number, segments: number) {
      const geometry = new THREE.BufferGeometry();
      const positions: number[] = [];
      const uvs: number[] = [];
      const indices: number[] = [];
      // Center
      positions.push(0, 0, 0);
      uvs.push(0.5, 0.5);
      // Ring vertices
      for (let r = 1; r <= rings; r++) {
        const ratio = r / rings;
        const rad = radius * ratio;
        for (let s = 0; s < segments; s++) {
          const theta = (s / segments) * Math.PI * 2;
          const x = Math.cos(theta) * rad;
          const y = Math.sin(theta) * rad;
          positions.push(x, y, 0);
          uvs.push(0.5 + (x / radius) * 0.5, 0.5 + (y / radius) * 0.5);
        }
      }
      // Inner fan: center → ring 1
      for (let s = 0; s < segments; s++) {
        const next = (s + 1) % segments;
        indices.push(0, 1 + s, 1 + next);
      }
      // Outer rings
      for (let r = 0; r < rings - 1; r++) {
        const inner = 1 + r * segments;
        const outer = 1 + (r + 1) * segments;
        for (let s = 0; s < segments; s++) {
          const next = (s + 1) % segments;
          indices.push(inner + s, outer + s, inner + next);
          indices.push(inner + next, outer + s, outer + next);
        }
      }
      geometry.setAttribute(
        "position",
        new THREE.Float32BufferAttribute(positions, 3),
      );
      geometry.setAttribute("uv", new THREE.Float32BufferAttribute(uvs, 2));
      geometry.setIndex(indices);
      geometry.computeVertexNormals();
      return geometry;
    }
    // ~50k triangles — plenty of vertex density for displacement detail.
    const discGeometry = createDisc(RADIUS, 160, 192);

    // ====== Face textures (gold coin) ======================================
    // Two canvases:
    //   1) color/roughness — radial gold gradient + raised logo + groove ring
    //   2) bump            — neutral gray field, white logo, black groove
    const HALF = FACE_SIZE / 2;
    const GROOVE_SHADOW_R = HALF * 0.9;
    const GROOVE_HIGHLIGHT_R = HALF * 0.92;

    // --- COLOR CANVAS ---
    const colorCanvas = document.createElement("canvas");
    colorCanvas.width = FACE_SIZE;
    colorCanvas.height = FACE_SIZE;
    const cctx = colorCanvas.getContext("2d")!;
    // Radial gold gradient: bright center, darker outer
    const goldGrad = cctx.createRadialGradient(
      HALF,
      HALF,
      0,
      HALF,
      HALF,
      HALF,
    );
    goldGrad.addColorStop(0.0, "#e8c060");
    goldGrad.addColorStop(1.0, "#a07010");
    cctx.fillStyle = goldGrad;
    cctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);

    // Subtle radial hatching for engraving texture
    cctx.strokeStyle = "rgba(120, 80, 20, 0.18)";
    cctx.lineWidth = 1;
    for (let i = 0; i < 180; i++) {
      const angle = (i / 180) * Math.PI * 2;
      cctx.beginPath();
      cctx.moveTo(
        HALF + Math.cos(angle) * HALF * 0.15,
        HALF + Math.sin(angle) * HALF * 0.15,
      );
      cctx.lineTo(
        HALF + Math.cos(angle) * HALF * 0.85,
        HALF + Math.sin(angle) * HALF * 0.85,
      );
      cctx.stroke();
    }

    // Concentric groove ring near the rim — dark shadow + bright highlight
    cctx.strokeStyle = "#7a5000";
    cctx.lineWidth = 2;
    cctx.beginPath();
    cctx.arc(HALF, HALF, GROOVE_SHADOW_R, 0, Math.PI * 2);
    cctx.stroke();
    cctx.strokeStyle = "#f0d080";
    cctx.beginPath();
    cctx.arc(HALF, HALF, GROOVE_HIGHLIGHT_R, 0, Math.PI * 2);
    cctx.stroke();

    const colorTexture = new THREE.CanvasTexture(colorCanvas);
    colorTexture.colorSpace = THREE.SRGBColorSpace;
    colorTexture.anisotropy = 8;

    // Used as roughnessMap too — brighter logo = slightly less rough
    const roughnessTexture = colorTexture;

    // --- BUMP CANVAS ---
    const bumpCanvas = document.createElement("canvas");
    bumpCanvas.width = FACE_SIZE;
    bumpCanvas.height = FACE_SIZE;
    const bctx = bumpCanvas.getContext("2d")!;
    bctx.fillStyle = "#808080"; // neutral height
    bctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    // Groove ring (recessed)
    bctx.strokeStyle = "#000000";
    bctx.lineWidth = 4;
    bctx.beginPath();
    bctx.arc(HALF, HALF, GROOVE_SHADOW_R, 0, Math.PI * 2);
    bctx.stroke();

    const bumpTexture = new THREE.CanvasTexture(bumpCanvas);
    bumpTexture.colorSpace = THREE.NoColorSpace;
    bumpTexture.anisotropy = 8;

    // Load logo and overlay onto both canvases.
    const logoImg = new Image();
    logoImg.onload = () => {
      console.log("[coin v7] logo loaded — painting gold face");

      // Sample logo pixels (mirrored on X so it isn't backwards on cap)
      const temp = document.createElement("canvas");
      temp.width = FACE_SIZE;
      temp.height = FACE_SIZE;
      const tctx = temp.getContext("2d")!;
      tctx.drawImage(logoImg, 0, 0, FACE_SIZE, FACE_SIZE);
      const logoData = tctx.getImageData(0, 0, FACE_SIZE, FACE_SIZE).data;

      // Build an alpha mask of the logo's bright pixels, mirrored.
      const logoMask = document.createElement("canvas");
      logoMask.width = FACE_SIZE;
      logoMask.height = FACE_SIZE;
      const mctx = logoMask.getContext("2d")!;
      const maskImg = mctx.createImageData(FACE_SIZE, FACE_SIZE);
      const mpx = maskImg.data;
      for (let y = 0; y < FACE_SIZE; y++) {
        for (let x = 0; x < FACE_SIZE; x++) {
          const srcX = FACE_SIZE - 1 - x;
          const si = (y * FACE_SIZE + srcX) * 4;
          const lum =
            0.299 * logoData[si] +
            0.587 * logoData[si + 1] +
            0.114 * logoData[si + 2];
          const a = Math.max(0, Math.min(255, (lum - 40) * 2.4));
          const di = (y * FACE_SIZE + x) * 4;
          mpx[di] = mpx[di + 1] = mpx[di + 2] = 255;
          mpx[di + 3] = a;
        }
      }
      mctx.putImageData(maskImg, 0, 0);

      // --- Paint logo on COLOR canvas in bright gold ---
      const goldLogo = document.createElement("canvas");
      goldLogo.width = FACE_SIZE;
      goldLogo.height = FACE_SIZE;
      const gctx = goldLogo.getContext("2d")!;
      gctx.fillStyle = "#f0d060";
      gctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
      gctx.globalCompositeOperation = "destination-in";
      gctx.drawImage(logoMask, 0, 0);
      cctx.drawImage(goldLogo, 0, 0);
      colorTexture.needsUpdate = true;

      // --- Paint logo on BUMP canvas in white (raised) ---
      const whiteLogo = document.createElement("canvas");
      whiteLogo.width = FACE_SIZE;
      whiteLogo.height = FACE_SIZE;
      const wctx = whiteLogo.getContext("2d")!;
      wctx.fillStyle = "#ffffff";
      wctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
      wctx.globalCompositeOperation = "destination-in";
      wctx.drawImage(logoMask, 0, 0);
      bctx.drawImage(whiteLogo, 0, 0);
      bumpTexture.needsUpdate = true;
      console.log("[coin v7] gold logo + bump painted");
    };
    logoImg.onerror = (err) => {
      console.error("[coin v7] FAILED to load logo-mark.png", err);
    };
    logoImg.src = "/images/brand/logo-mark.png";

    // ====== Materials (polished/satin gold) ================================
    const faceMaterial = new THREE.MeshPhysicalMaterial({
      color: 0xd4a017, // warm gold base
      map: colorTexture,
      roughnessMap: roughnessTexture,
      bumpMap: bumpTexture,
      bumpScale: 0.8,
      metalness: 0.95,
      roughness: 0.25,
      envMapIntensity: 2.5,
      reflectivity: 1.0,
      clearcoat: 0.3,
      clearcoatRoughness: 0.15,
    });

    // ====== Edge (reeded gold grooves on a hollow cylinder) ================
    const grooveCount = 100;
    const grooveCanvas = document.createElement("canvas");
    grooveCanvas.width = grooveCount * 4;
    grooveCanvas.height = 32;
    const gctx = grooveCanvas.getContext("2d")!;
    gctx.fillStyle = "#b8861a"; // mid gold
    gctx.fillRect(0, 0, grooveCanvas.width, grooveCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * grooveCanvas.width;
      gctx.fillStyle = "#f0d060"; // bright gold ridge
      gctx.fillRect(x, 0, 2, grooveCanvas.height);
      gctx.fillStyle = "#6a4a08"; // dark gold groove
      gctx.fillRect(x + 2, 0, 2, grooveCanvas.height);
    }
    const grooveTexture = new THREE.CanvasTexture(grooveCanvas);
    grooveTexture.colorSpace = THREE.SRGBColorSpace;
    grooveTexture.wrapS = THREE.RepeatWrapping;
    grooveTexture.wrapT = THREE.ClampToEdgeWrapping;
    grooveTexture.anisotropy = 8;

    const grooveBumpCanvas = document.createElement("canvas");
    grooveBumpCanvas.width = grooveCount * 4;
    grooveBumpCanvas.height = 32;
    const gbctx = grooveBumpCanvas.getContext("2d")!;
    gbctx.fillStyle = "#808080";
    gbctx.fillRect(0, 0, grooveBumpCanvas.width, grooveBumpCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * grooveBumpCanvas.width;
      gbctx.fillStyle = "#ffffff";
      gbctx.fillRect(x, 0, 2, grooveBumpCanvas.height);
      gbctx.fillStyle = "#000000";
      gbctx.fillRect(x + 2, 0, 2, grooveBumpCanvas.height);
    }
    const grooveBump = new THREE.CanvasTexture(grooveBumpCanvas);
    grooveBump.wrapS = THREE.RepeatWrapping;
    grooveBump.wrapT = THREE.ClampToEdgeWrapping;

    const edgeMaterial = new THREE.MeshPhysicalMaterial({
      color: 0xd4a017,
      map: grooveTexture,
      bumpMap: grooveBump,
      bumpScale: 0.25,
      metalness: 0.95,
      roughness: 0.35,
      envMapIntensity: 2.5,
      reflectivity: 1.0,
      clearcoat: 0.3,
      clearcoatRoughness: 0.15,
    });

    // ====== Coin construction ==============================================
    // Two disc meshes (front + back) plus an open-ended cylinder for the
    // edge. Discs sit at ±THICKNESS/2 so the cylinder fills between them.
    const coin = new THREE.Group();

    const frontFace = new THREE.Mesh(discGeometry, faceMaterial);
    frontFace.position.z = THICKNESS / 2;
    coin.add(frontFace);

    const backFace = new THREE.Mesh(discGeometry, faceMaterial);
    backFace.position.z = -THICKNESS / 2;
    backFace.scale.set(1, 1, -1); // flip normals → faces -Z
    coin.add(backFace);

    const sideGeo = new THREE.CylinderGeometry(
      RADIUS,
      RADIUS,
      THICKNESS,
      96,
      1,
      true, // openEnded
    );
    const edgeMesh = new THREE.Mesh(sideGeo, edgeMaterial);
    edgeMesh.rotation.x = Math.PI / 2; // align with Z-aligned discs
    coin.add(edgeMesh);

    // More pronounced tilt so the rim thickness reads
    coin.rotation.x = -0.22;
    scene.add(coin);

    // ====== Lighting (gold-coin photo-style) ===============================
    const ambient = new THREE.AmbientLight(0x222200, 0.3);
    scene.add(ambient);

    const keyLight = new THREE.PointLight(0xfff0cc, 2.5);
    keyLight.position.set(4, 6, 5);
    scene.add(keyLight);

    const fillLight = new THREE.PointLight(0xffd090, 0.6);
    fillLight.position.set(-3, -1, 3);
    scene.add(fillLight);

    // Studio-lightbox style HDR-ish environment: bright top, neutral
    // mid, dark floor. Gives the coin a strong specular sweep from
    // above and a dark bottom that sells the 3D form.
    const envCanvas = document.createElement("canvas");
    envCanvas.width = 1024;
    envCanvas.height = 512;
    const envCtx = envCanvas.getContext("2d")!;
    // Top zone (0–30%): bright warm studio light
    const topGrad = envCtx.createLinearGradient(0, 0, 0, 512 * 0.3);
    topGrad.addColorStop(0.0, "#ffffff");
    topGrad.addColorStop(1.0, "#e8d090");
    envCtx.fillStyle = topGrad;
    envCtx.fillRect(0, 0, 1024, 512 * 0.3);
    // Mid zone (30–80%): neutral gray
    envCtx.fillStyle = "#aaaaaa";
    envCtx.fillRect(0, 512 * 0.3, 1024, 512 * 0.5);
    // Floor (80–100%): dark
    envCtx.fillStyle = "#222222";
    envCtx.fillRect(0, 512 * 0.8, 1024, 512 * 0.2);

    const envSource = new THREE.CanvasTexture(envCanvas);
    envSource.mapping = THREE.EquirectangularReflectionMapping;
    envSource.colorSpace = THREE.SRGBColorSpace;
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromEquirectangular(envSource).texture;
    envSource.dispose();
    pmrem.dispose();

    // ====== Animation ======================================================
    const speed = 0.003; // slower, more premium rotation
    const animate = () => {
      if (!reducedMotion) coin.rotation.y += speed;
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();

    const ro = new ResizeObserver(resize);
    ro.observe(mount);
  }
</script>
