---
import Button from "./Button.astro";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-20 md:pt-44 md:pb-28 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative z-10 max-w-xl">
        <h1
          class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6 text-cream"
        >
          How we make decisions together to advance quantum biology
        </h1>
        <div
          class="font-sans text-base sm:text-lg text-cream/70 leading-relaxed space-y-5 mb-10"
        >
          <p>
            Quantum Biology DAO is a decentralized organization that supports
            open scientific research at the frontier of biology and physics. We
            support experiments, technologies, and ideas that explore how
            quantum physics may influence living systems.
          </p>
          <p>
            Instead of relying on a central leader or institution, decisions are
            made collectively. Through transparent governance and shared digital
            tools, our community directs funding, sets priorities, and helps
            shape the future of quantum biology research.
          </p>
          <p>
            At the center of this process is QBIO, the governance token that
            powers the DAO.
          </p>
        </div>
        <Button href="#what-is-qbio" variant="primary" size="md"
          >Learn about QBIO</Button
        >
      </div>
      <div class="relative">
        <div
          id="qbio-coin-3d"
          class="w-full max-w-md mx-auto aspect-square"
          role="img"
          aria-label="3D rendering of the QBIO governance token, slowly spinning"
        ></div>
        <noscript>
          <img
            src="/images/graphics/coin.png"
            alt="QBIO governance token"
            class="w-full h-auto max-w-md mx-auto"
          />
        </noscript>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  console.log("[coin v12] script start — single-cylinder gold-style purple");

  const mount = document.getElementById("qbio-coin-3d");
  if (mount) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // ====== Scene + Camera + Renderer ======================================
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 100);
    camera.position.set(0, 0, 9);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const resize = () => {
      const size = Math.min(mount.clientWidth, 520);
      renderer.setSize(size, size, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    };
    resize();
    mount.appendChild(renderer.domElement);

    // ====== GEOMETRY =======================================================
    const RADIUS = 2;
    const THICKNESS = 0.38;
    const RADIAL_SEGMENTS = 128;
    const geometry = new THREE.CylinderGeometry(
      RADIUS,
      RADIUS,
      THICKNESS,
      RADIAL_SEGMENTS,
    );

    // ====== ENVIRONMENT MAP — brand-tinted studio =========================
    // Toned down vs v12: pure white reflections were washing the coin
    // out toward bone instead of purple. Top zone now pale pink → brand
    // magenta, and the key spotlight is pink instead of white.
    const envCanvas = document.createElement("canvas");
    envCanvas.width = 1024;
    envCanvas.height = 512;
    const ec = envCanvas.getContext("2d")!;
    const topGrad = ec.createLinearGradient(0, 0, 0, 154);
    topGrad.addColorStop(0, "#ffe8f4");
    topGrad.addColorStop(1, "#d57db2");
    ec.fillStyle = topGrad;
    ec.fillRect(0, 0, 1024, 154);
    ec.fillStyle = "#4b243c";
    ec.fillRect(0, 154, 1024, 204);
    ec.fillStyle = "#0f060d";
    ec.fillRect(0, 358, 1024, 154);
    // Soft pink key-light reflection in the upper-left
    const spot = ec.createRadialGradient(200, 80, 0, 200, 80, 180);
    spot.addColorStop(0, "rgba(255,206,236,0.9)");
    spot.addColorStop(1, "rgba(255,206,236,0)");
    ec.fillStyle = spot;
    ec.fillRect(0, 0, 512, 300);

    const envSource = new THREE.CanvasTexture(envCanvas);
    envSource.mapping = THREE.EquirectangularReflectionMapping;
    envSource.colorSpace = THREE.SRGBColorSpace;
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromEquirectangular(envSource).texture;
    envSource.dispose();
    pmrem.dispose();

    // ====== FACE TEXTURES ==================================================
    const FACE_SIZE = 512;
    const HALF = FACE_SIZE / 2;
    const RIM_OUTER_R = 248;
    const RIM_INNER_R = 230;
    const STEP_INNER_R = 222;
    const LOGO_PAD = 64;
    const LOGO_SIZE = FACE_SIZE - LOGO_PAD * 2;

    // --- COLOR CANVAS ---
    const faceCanvas = document.createElement("canvas");
    faceCanvas.width = FACE_SIZE;
    faceCanvas.height = FACE_SIZE;
    const fc = faceCanvas.getContext("2d")!;
    // Slightly lighter center → very dark edge: concave field illusion
    const bgGrad = fc.createRadialGradient(HALF, HALF, 0, HALF, HALF, HALF);
    bgGrad.addColorStop(0.0, "#5c2a4a");
    bgGrad.addColorStop(0.6, "#3d1a38");
    bgGrad.addColorStop(1.0, "#25101d");
    fc.fillStyle = bgGrad;
    fc.fillRect(0, 0, FACE_SIZE, FACE_SIZE);

    // Faint repeating hex grid in the field, clipped to inside the rim
    const HEX_TILE = 22;
    const hexTile = document.createElement("canvas");
    hexTile.width = HEX_TILE * 1.5;
    hexTile.height = HEX_TILE * Math.sqrt(3);
    const htc = hexTile.getContext("2d")!;
    htc.strokeStyle = "rgba(255, 206, 236, 0.08)";
    htc.lineWidth = 0.6;
    const drawHex = (cx0: number, cy0: number) => {
      const r = HEX_TILE * 0.5;
      htc.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (i * Math.PI) / 3;
        const x = cx0 + Math.cos(a) * r;
        const y = cy0 + Math.sin(a) * r;
        if (i === 0) htc.moveTo(x, y);
        else htc.lineTo(x, y);
      }
      htc.closePath();
      htc.stroke();
    };
    drawHex(HEX_TILE * 0.5, hexTile.height * 0.5);
    drawHex(HEX_TILE * 0.5 + HEX_TILE * 1.5, 0);
    drawHex(HEX_TILE * 0.5 + HEX_TILE * 1.5, hexTile.height);
    drawHex(-HEX_TILE * 0.5, 0);
    drawHex(-HEX_TILE * 0.5, hexTile.height);
    const hexPattern = fc.createPattern(hexTile, "repeat")!;
    fc.save();
    fc.beginPath();
    fc.arc(HALF, HALF, RIM_INNER_R, 0, Math.PI * 2);
    fc.clip();
    fc.fillStyle = hexPattern;
    fc.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    fc.restore();

    // Raised rim ring (brighter purple)
    fc.beginPath();
    fc.arc(HALF, HALF, RIM_OUTER_R, 0, Math.PI * 2);
    fc.arc(HALF, HALF, RIM_INNER_R, 0, Math.PI * 2, true);
    fc.fillStyle = "#854b6e";
    fc.fill("evenodd");

    // Inner step / shadow line just inside the rim
    fc.beginPath();
    fc.arc(HALF, HALF, RIM_INNER_R, 0, Math.PI * 2);
    fc.arc(HALF, HALF, STEP_INNER_R, 0, Math.PI * 2, true);
    fc.fillStyle = "#1a0818";
    fc.fill("evenodd");

    const faceTex = new THREE.CanvasTexture(faceCanvas);
    faceTex.colorSpace = THREE.SRGBColorSpace;
    faceTex.anisotropy = 16;

    // --- BUMP CANVAS ---
    const bumpCanvas = document.createElement("canvas");
    bumpCanvas.width = FACE_SIZE;
    bumpCanvas.height = FACE_SIZE;
    const bc = bumpCanvas.getContext("2d")!;
    bc.fillStyle = "#000000"; // maximally recessed field
    bc.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    // Rim = white = raised
    bc.beginPath();
    bc.arc(HALF, HALF, RIM_OUTER_R, 0, Math.PI * 2);
    bc.arc(HALF, HALF, RIM_INNER_R, 0, Math.PI * 2, true);
    bc.fillStyle = "#e0e0e0";
    bc.fill("evenodd");
    // Inner step groove = dark gray
    bc.beginPath();
    bc.arc(HALF, HALF, RIM_INNER_R, 0, Math.PI * 2);
    bc.arc(HALF, HALF, STEP_INNER_R, 0, Math.PI * 2, true);
    bc.fillStyle = "#222222";
    bc.fill("evenodd");
    const bumpTex = new THREE.CanvasTexture(bumpCanvas);
    bumpTex.colorSpace = THREE.NoColorSpace;
    bumpTex.anisotropy = 16;

    // --- ROUGHNESS CANVAS ---
    // brighter = rougher; logo will be painted very dark = shiny.
    const roughCanvas = document.createElement("canvas");
    roughCanvas.width = FACE_SIZE;
    roughCanvas.height = FACE_SIZE;
    const rc = roughCanvas.getContext("2d")!;
    rc.fillStyle = "#aaaaaa"; // field: rough
    rc.fillRect(0, 0, FACE_SIZE, FACE_SIZE);
    rc.beginPath(); // rim: medium
    rc.arc(HALF, HALF, RIM_OUTER_R, 0, Math.PI * 2);
    rc.arc(HALF, HALF, STEP_INNER_R, 0, Math.PI * 2, true);
    rc.fillStyle = "#555555";
    rc.fill("evenodd");

    // Micro-noise across the roughness map: makes the surface read as
    // actual metal (brushed/imperfect) instead of glassy plastic.
    {
      const noiseImg = rc.getImageData(0, 0, FACE_SIZE, FACE_SIZE);
      const npx = noiseImg.data;
      for (let i = 0; i < npx.length; i += 4) {
        const jitter = (Math.random() - 0.5) * 36;
        npx[i] = Math.max(0, Math.min(255, npx[i] + jitter));
        npx[i + 1] = Math.max(0, Math.min(255, npx[i + 1] + jitter));
        npx[i + 2] = Math.max(0, Math.min(255, npx[i + 2] + jitter));
      }
      rc.putImageData(noiseImg, 0, 0);
    }
    const roughTex = new THREE.CanvasTexture(roughCanvas);
    roughTex.colorSpace = THREE.NoColorSpace;
    roughTex.anisotropy = 16;

    // ====== LOGO COMPOSITE (alpha-keyed because logo PNG is opaque) =======
    const logoImg = new Image();
    logoImg.onload = () => {
      console.log("[coin v12] logo loaded, painting maps");

      // Build a per-pixel mask: bright glyph pixels → opaque, dark
      // plum background → transparent. Then composite the masked logo
      // onto each map in the desired color.
      const tintLogo = (tintHex: string) => {
        const c = document.createElement("canvas");
        c.width = LOGO_SIZE;
        c.height = LOGO_SIZE;
        const ctx = c.getContext("2d")!;
        // Flip horizontally so the logo isn't backwards on the cap
        ctx.translate(LOGO_SIZE, 0);
        ctx.scale(-1, 1);
        ctx.drawImage(logoImg, 0, 0, LOGO_SIZE, LOGO_SIZE);
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        const tR = parseInt(tintHex.slice(1, 3), 16);
        const tG = parseInt(tintHex.slice(3, 5), 16);
        const tB = parseInt(tintHex.slice(5, 7), 16);
        const data = ctx.getImageData(0, 0, LOGO_SIZE, LOGO_SIZE);
        const px = data.data;
        for (let i = 0; i < px.length; i += 4) {
          const lum = 0.299 * px[i] + 0.587 * px[i + 1] + 0.114 * px[i + 2];
          const a = Math.max(0, Math.min(255, (lum - 40) * 2.4));
          px[i] = tR;
          px[i + 1] = tG;
          px[i + 2] = tB;
          px[i + 3] = a;
        }
        ctx.putImageData(data, 0, 0);
        return c;
      };

      // COLOR — bright magenta paint where the logo is raised
      fc.drawImage(tintLogo("#d57db2"), LOGO_PAD, LOGO_PAD);
      faceTex.needsUpdate = true;

      // BUMP — pure white = maximum raise
      bc.drawImage(tintLogo("#ffffff"), LOGO_PAD, LOGO_PAD);
      bumpTex.needsUpdate = true;

      // ROUGHNESS — near-black so the raised logo reads as the shiniest
      // part of the coin (smooth/reflective vs the rougher field)
      rc.drawImage(tintLogo("#111111"), LOGO_PAD, LOGO_PAD);
      roughTex.needsUpdate = true;
    };
    logoImg.onerror = (err) => {
      console.error("[coin v12] FAILED to load logo-mark.png", err);
    };
    logoImg.src = "/images/brand/logo-mark.png";

    // ====== FACE MATERIAL ==================================================
    const faceMat = new THREE.MeshPhysicalMaterial({
      map: faceTex,
      bumpMap: bumpTex,
      bumpScale: 5.5, // deeper relief on rim/logo
      roughnessMap: roughTex,
      metalness: 0.92,
      roughness: 0.32,
      envMapIntensity: 2.2, // toned down so brand purple isn't washed out
      color: 0x6d3a5a, // slightly darker, more saturated purple
      clearcoat: 0.5,
      clearcoatRoughness: 0.12,
    });

    // ====== RIM (edge) — reeded grooves with REAL bump map ================
    const RIM_W = 512;
    const RIM_H = 64;
    const notchCount = 120;

    const rimCanvas = document.createElement("canvas");
    rimCanvas.width = RIM_W;
    rimCanvas.height = RIM_H;
    const rmc = rimCanvas.getContext("2d")!;
    rmc.fillStyle = "#2c1428";
    rmc.fillRect(0, 0, RIM_W, RIM_H);
    for (let i = 0; i < notchCount; i++) {
      const x = (i / notchCount) * RIM_W;
      rmc.fillStyle = "#7a3a60";
      rmc.fillRect(x, 0, 3, RIM_H);
      rmc.fillStyle = "#100608";
      rmc.fillRect(x + 3, 0, 1, RIM_H);
    }
    const rimColorTex = new THREE.CanvasTexture(rimCanvas);
    rimColorTex.wrapS = THREE.RepeatWrapping;
    rimColorTex.wrapT = THREE.RepeatWrapping;
    rimColorTex.colorSpace = THREE.SRGBColorSpace;
    rimColorTex.anisotropy = 8;

    // Matching grayscale bumpMap: white where the ridge sits, black in
    // the groove. Same notch geometry as the color texture so the
    // visible stripe and the cast shadow line up. Without this the
    // ridges are just paint and never shift with the lighting.
    const rimBumpCanvas = document.createElement("canvas");
    rimBumpCanvas.width = RIM_W;
    rimBumpCanvas.height = RIM_H;
    const rbc = rimBumpCanvas.getContext("2d")!;
    rbc.fillStyle = "#808080";
    rbc.fillRect(0, 0, RIM_W, RIM_H);
    for (let i = 0; i < notchCount; i++) {
      const x = (i / notchCount) * RIM_W;
      rbc.fillStyle = "#ffffff";
      rbc.fillRect(x, 0, 3, RIM_H);
      rbc.fillStyle = "#000000";
      rbc.fillRect(x + 3, 0, 1, RIM_H);
    }
    const rimBumpTex = new THREE.CanvasTexture(rimBumpCanvas);
    rimBumpTex.wrapS = THREE.RepeatWrapping;
    rimBumpTex.wrapT = THREE.RepeatWrapping;
    rimBumpTex.colorSpace = THREE.NoColorSpace;
    rimBumpTex.anisotropy = 8;

    const rimMat = new THREE.MeshPhysicalMaterial({
      map: rimColorTex,
      bumpMap: rimBumpTex,
      bumpScale: 0.35, // pronounced ridges that catch light during spin
      metalness: 0.95,
      roughness: 0.35,
      envMapIntensity: 2.2,
      color: 0x4b243c,
    });

    // ====== ASSEMBLE =======================================================
    // Cylinder material order: [side, top, bottom]
    const mesh = new THREE.Mesh(geometry, [rimMat, faceMat, faceMat]);
    const pivot = new THREE.Group();
    pivot.add(mesh);
    mesh.rotation.x = Math.PI / 2; // tip cylinder so faces point at camera
    pivot.rotation.x = -0.22; // tilt so thickness reads
    scene.add(pivot);

    // ====== LIGHTS =========================================================
    scene.add(new THREE.AmbientLight(0x1a0818, 0.4));

    const keyLight = new THREE.PointLight(0xfff0f8, 3.5);
    keyLight.position.set(4, 6, 6);
    scene.add(keyLight);

    const fillLight = new THREE.PointLight(0xd57db2, 0.8);
    fillLight.position.set(-5, -2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.PointLight(0xffceec, 1.2);
    rimLight.position.set(-3, 4, -4);
    scene.add(rimLight);

    // ====== ANIMATE ========================================================
    const rotSpeed = 0.004;
    const animate = () => {
      if (!reducedMotion) pivot.rotation.y += rotSpeed;
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();

    new ResizeObserver(resize).observe(mount);
  }
</script>
