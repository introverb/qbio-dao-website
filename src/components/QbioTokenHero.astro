---
import Button from "./Button.astro";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-20 md:pt-44 md:pb-28 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative z-10 max-w-xl">
        <h1
          class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6 text-cream"
        >
          How we make decisions together to advance quantum biology
        </h1>
        <div
          class="font-sans text-base sm:text-lg text-cream/70 leading-relaxed space-y-5 mb-10"
        >
          <p>
            Quantum Biology DAO is a decentralized organization that supports
            open scientific research at the frontier of biology and physics. We
            support experiments, technologies, and ideas that explore how
            quantum physics may influence living systems.
          </p>
          <p>
            Instead of relying on a central leader or institution, decisions are
            made collectively. Through transparent governance and shared digital
            tools, our community directs funding, sets priorities, and helps
            shape the future of quantum biology research.
          </p>
          <p>
            At the center of this process is QBIO, the governance token that
            powers the DAO.
          </p>
        </div>
        <Button href="#what-is-qbio" variant="primary" size="md"
          >Learn about QBIO</Button
        >
      </div>
      <div class="relative">
        <div
          id="qbio-coin-3d"
          class="w-full max-w-md mx-auto aspect-square"
          role="img"
          aria-label="3D rendering of the QBIO governance token, slowly spinning"
        ></div>
        <noscript>
          <img
            src="/images/graphics/coin.png"
            alt="QBIO governance token"
            class="w-full h-auto max-w-md mx-auto"
          />
        </noscript>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  const mount = document.getElementById("qbio-coin-3d");
  if (mount) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 100);
    camera.position.set(0, 0, 9);

    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const resize = () => {
      const size = Math.min(mount.clientWidth, 520);
      renderer.setSize(size, size, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    };
    resize();
    mount.appendChild(renderer.domElement);

    // Round coin geometry — 96 segments for a smooth curved rim.
    const radius = 2;
    const thickness = 0.42;
    const radialSegments = 96;
    const geometry = new THREE.CylinderGeometry(
      radius,
      radius,
      thickness,
      radialSegments,
    );

    // Face: build a HEIGHT map and a COLOR map from logo-mark.png, then
    // derive a NORMAL map from the height map. Normal maps give much
    // more reliable relief than bumpMap with MeshStandardMaterial,
    // especially when metalness > 0.
    const FACE_SIZE = 1024;
    const BASE_PURPLE = "#6b4c6b";
    const PEAK_PURPLE = "#c190d0";

    // Height canvas (grayscale, used to derive the normal map)
    const heightCanvas = document.createElement("canvas");
    heightCanvas.width = FACE_SIZE;
    heightCanvas.height = FACE_SIZE;
    const hctx = heightCanvas.getContext("2d")!;
    hctx.translate(FACE_SIZE, 0);
    hctx.scale(-1, 1);
    hctx.fillStyle = "#000000";
    hctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);

    // Color canvas (purple base, light-purple painted on the logo)
    const faceColorCanvas = document.createElement("canvas");
    faceColorCanvas.width = FACE_SIZE;
    faceColorCanvas.height = FACE_SIZE;
    const fcctx = faceColorCanvas.getContext("2d")!;
    fcctx.translate(FACE_SIZE, 0);
    fcctx.scale(-1, 1);
    fcctx.fillStyle = BASE_PURPLE;
    fcctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);

    // Normal map canvas — populated after we have height data
    const normalCanvas = document.createElement("canvas");
    normalCanvas.width = FACE_SIZE;
    normalCanvas.height = FACE_SIZE;
    const nctx = normalCanvas.getContext("2d")!;
    // Default "flat up" normal so the texture is valid before the
    // logo loads (RGB encoding of (0, 0, 1) → (128, 128, 255)).
    nctx.fillStyle = "rgb(128, 128, 255)";
    nctx.fillRect(0, 0, FACE_SIZE, FACE_SIZE);

    const faceColorTexture = new THREE.CanvasTexture(faceColorCanvas);
    faceColorTexture.colorSpace = THREE.SRGBColorSpace;
    faceColorTexture.anisotropy = 8;

    const faceNormalTexture = new THREE.CanvasTexture(normalCanvas);
    faceNormalTexture.colorSpace = THREE.NoColorSpace;
    faceNormalTexture.anisotropy = 8;

    const logoImg = new Image();
    logoImg.onload = () => {
      console.log("[coin] logo loaded, painting maps...");

      // 1) HEIGHT — draw logo and luminance-stretch it
      hctx.drawImage(logoImg, 0, 0, FACE_SIZE, FACE_SIZE);
      try {
        const data = hctx.getImageData(0, 0, FACE_SIZE, FACE_SIZE);
        const px = data.data;
        for (let i = 0; i < px.length; i += 4) {
          const lum =
            0.299 * px[i] + 0.587 * px[i + 1] + 0.114 * px[i + 2];
          const stretched = Math.max(0, Math.min(255, (lum - 40) * 2.2));
          px[i] = px[i + 1] = px[i + 2] = stretched;
          px[i + 3] = 255;
        }
        hctx.putImageData(data, 0, 0);

        // 2) NORMAL — finite differences of the height map encoded as RGB.
        // (-dx, -dy, 1) normalized, then mapped from [-1,1] → [0,255].
        const heightData = data.data;
        const normalImg = nctx.createImageData(FACE_SIZE, FACE_SIZE);
        const nd = normalImg.data;
        const strength = 8.0; // multiplies the slope — higher = steeper
        const w = FACE_SIZE;
        for (let y = 0; y < FACE_SIZE; y++) {
          for (let x = 0; x < FACE_SIZE; x++) {
            const xL = x === 0 ? 0 : x - 1;
            const xR = x === FACE_SIZE - 1 ? FACE_SIZE - 1 : x + 1;
            const yU = y === 0 ? 0 : y - 1;
            const yD = y === FACE_SIZE - 1 ? FACE_SIZE - 1 : y + 1;
            const hL = heightData[(y * w + xL) * 4];
            const hR = heightData[(y * w + xR) * 4];
            const hU = heightData[(yU * w + x) * 4];
            const hD = heightData[(yD * w + x) * 4];
            const dx = ((hR - hL) / 255) * strength;
            const dy = ((hD - hU) / 255) * strength;
            const nx = -dx;
            const ny = -dy;
            const nz = 1.0;
            const len = Math.sqrt(nx * nx + ny * ny + nz * nz);
            const idx = (y * w + x) * 4;
            nd[idx] = Math.round((nx / len) * 0.5 * 255 + 127.5);
            nd[idx + 1] = Math.round((ny / len) * 0.5 * 255 + 127.5);
            nd[idx + 2] = Math.round((nz / len) * 0.5 * 255 + 127.5);
            nd[idx + 3] = 255;
          }
        }
        nctx.putImageData(normalImg, 0, 0);
        faceNormalTexture.needsUpdate = true;
        console.log("[coin] normal map generated");
      } catch (err) {
        console.warn("Height/normal generation failed:", err);
      }

      // 3) COLOR — paint PEAK_PURPLE on top of the base where the logo
      //    is bright.
      try {
        const off = document.createElement("canvas");
        off.width = FACE_SIZE;
        off.height = FACE_SIZE;
        const octx = off.getContext("2d")!;
        octx.drawImage(logoImg, 0, 0, FACE_SIZE, FACE_SIZE);
        const data = octx.getImageData(0, 0, FACE_SIZE, FACE_SIZE);
        const px = data.data;
        const pr = parseInt(PEAK_PURPLE.slice(1, 3), 16);
        const pg = parseInt(PEAK_PURPLE.slice(3, 5), 16);
        const pb = parseInt(PEAK_PURPLE.slice(5, 7), 16);
        for (let i = 0; i < px.length; i += 4) {
          const lum =
            0.299 * px[i] + 0.587 * px[i + 1] + 0.114 * px[i + 2];
          const alpha = Math.max(0, Math.min(255, (lum - 40) * 2.2));
          px[i] = pr;
          px[i + 1] = pg;
          px[i + 2] = pb;
          px[i + 3] = alpha;
        }
        octx.putImageData(data, 0, 0);
        fcctx.drawImage(off, 0, 0);
      } catch (err) {
        console.warn("Color composite failed:", err);
      }
      faceColorTexture.needsUpdate = true;
    };
    logoImg.onerror = (err) => {
      console.error("Failed to load /images/brand/logo-mark.png", err);
    };
    logoImg.src = "/images/brand/logo-mark.png";

    const faceMaterial = new THREE.MeshStandardMaterial({
      map: faceColorTexture,
      normalMap: faceNormalTexture,
      normalScale: new THREE.Vector2(3.0, 3.0), // very pronounced relief
      metalness: 0.25,
      roughness: 0.55,
      envMapIntensity: 0.4,
    });

    // Edge: reeded grooves with colors picked from QBIOTOKEN.png — mauve
    // base, light pink highlights, deep plum shadows.
    const grooveCount = 80;
    const grooveCanvas = document.createElement("canvas");
    grooveCanvas.width = grooveCount * 4;
    grooveCanvas.height = 32;
    const gctx = grooveCanvas.getContext("2d")!;
    gctx.fillStyle = "#6b4866"; // mid mauve body
    gctx.fillRect(0, 0, grooveCanvas.width, grooveCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * grooveCanvas.width;
      gctx.fillStyle = "#b48aa6"; // highlight ridge
      gctx.fillRect(x, 0, 2, grooveCanvas.height);
      gctx.fillStyle = "#2c1a30"; // shadow groove
      gctx.fillRect(x + 2, 0, 2, grooveCanvas.height);
    }
    const grooveTexture = new THREE.CanvasTexture(grooveCanvas);
    grooveTexture.colorSpace = THREE.SRGBColorSpace;
    grooveTexture.wrapS = THREE.RepeatWrapping;
    grooveTexture.wrapT = THREE.ClampToEdgeWrapping;
    grooveTexture.anisotropy = 8;

    // Bump map for the edge — grayscale stripes give the grooves
    // light-catching relief.
    const bumpCanvas = document.createElement("canvas");
    bumpCanvas.width = grooveCount * 4;
    bumpCanvas.height = 32;
    const bctx = bumpCanvas.getContext("2d")!;
    bctx.fillStyle = "#808080";
    bctx.fillRect(0, 0, bumpCanvas.width, bumpCanvas.height);
    for (let i = 0; i < grooveCount; i++) {
      const x = (i / grooveCount) * bumpCanvas.width;
      bctx.fillStyle = "#ffffff";
      bctx.fillRect(x, 0, 2, bumpCanvas.height);
      bctx.fillStyle = "#000000";
      bctx.fillRect(x + 2, 0, 2, bumpCanvas.height);
    }
    const grooveBump = new THREE.CanvasTexture(bumpCanvas);
    grooveBump.wrapS = THREE.RepeatWrapping;
    grooveBump.wrapT = THREE.ClampToEdgeWrapping;

    const edgeMaterial = new THREE.MeshStandardMaterial({
      map: grooveTexture,
      bumpMap: grooveBump,
      bumpScale: 0.2,
      metalness: 0.35,
      roughness: 0.55,
    });

    // CylinderGeometry materials order: [side, top, bottom]
    const coin = new THREE.Mesh(geometry, [
      edgeMaterial,
      faceMaterial,
      faceMaterial,
    ]);

    // Group lets us spin around world Y regardless of coin's tilt
    const group = new THREE.Group();
    group.add(coin);
    // Tip the cylinder so its faces look at the camera
    coin.rotation.x = Math.PI / 2;
    // Subtle forward tilt so it doesn't go fully edge-on at 90°
    group.rotation.x = -0.18;
    scene.add(group);

    // Directional key light from upper-right so the bump map's raised
    // outlines catch light on one side and cast shadow on the other —
    // the visual signal that sells the embossment as real relief.
    const ambient = new THREE.AmbientLight(0xffffff, 0.25);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xfff1e0, 1.2);
    keyLight.position.set(5, 8, 5);
    scene.add(keyLight);

    // Soft warm rim so the recessed side doesn't go to pure black
    const rimLight = new THREE.DirectionalLight(0xd57db2, 0.35);
    rimLight.position.set(-4, -2, -2);
    scene.add(rimLight);

    // Subtle neutral environment so the metallic component has
    // something to reflect (metal materials look dark without IBL).
    const envCanvas = document.createElement("canvas");
    envCanvas.width = 512;
    envCanvas.height = 256;
    const envCtx = envCanvas.getContext("2d")!;
    const envGrad = envCtx.createLinearGradient(0, 0, 0, 256);
    envGrad.addColorStop(0.0, "#d9c9d9");
    envGrad.addColorStop(0.5, "#7a5a7e");
    envGrad.addColorStop(1.0, "#1d0e1f");
    envCtx.fillStyle = envGrad;
    envCtx.fillRect(0, 0, 512, 256);

    const envSource = new THREE.CanvasTexture(envCanvas);
    envSource.mapping = THREE.EquirectangularReflectionMapping;
    envSource.colorSpace = THREE.SRGBColorSpace;

    const pmrem = new THREE.PMREMGenerator(renderer);
    const envRT = pmrem.fromEquirectangular(envSource);
    scene.environment = envRT.texture;
    envSource.dispose();
    pmrem.dispose();

    // Animation
    const speed = 0.005;
    const animate = () => {
      if (!reducedMotion) {
        group.rotation.y += speed;
      }
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();

    // Respond to container resizing
    const ro = new ResizeObserver(resize);
    ro.observe(mount);
  }
</script>
