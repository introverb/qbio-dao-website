---
interface Props {
  href: string;
  label: string;
  accent?: "gold" | "pink" | "teal";
  external?: boolean;
  size?: "md" | "sm";
}

const {
  href,
  label,
  accent = "gold",
  external = false,
  size = "md",
} = Astro.props;

const circleSize = size === "sm" ? "w-10 h-10" : "w-12 h-12";
const iconSize = size === "sm" ? 12 : 14;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class:list={[
    "inline-flex items-center gap-3 font-sans text-[11px] tracking-[0.3em] uppercase transition-colors group",
    accent === "gold" && "text-gold",
    accent === "pink" && "text-pink",
    accent === "teal" && "text-teal",
  ]}
>
  <span
    class:list={[
      "inline-flex items-center justify-center rounded-full border transition-colors",
      circleSize,
      accent === "gold" &&
        "bg-gold border-gold text-plum-darkest group-hover:bg-transparent group-hover:text-gold",
      accent === "pink" &&
        "bg-pink border-pink text-plum-darkest group-hover:bg-transparent group-hover:text-pink",
      accent === "teal" &&
        "bg-teal border-teal text-plum-darkest group-hover:bg-transparent group-hover:text-teal",
    ]}
  >
    <svg
      width={iconSize}
      height={iconSize}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      ><path d="M5 12h14"></path><polyline points="12 5 19 12 12 19"
      ></polyline></svg
    >
  </span>
  <span>{label}</span>
</a>
