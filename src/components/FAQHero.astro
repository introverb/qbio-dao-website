---
import Button from "./Button.astro";

const explainerUrl =
  "https://docs.google.com/document/d/1Eoye_Ltl_DybiZX59V87T3SO1Yx46St9_IBPGBFoSloY/edit?tab=t.0";
---

<section
  class="relative bg-plum-darkest text-cream pt-36 pb-16 md:pt-44 md:pb-20 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="border-y border-cream/15 py-10 md:py-14">
      <h1
        class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-cream text-center"
      >
        Frequently asked questions
      </h1>
    </div>

    <div class="max-w-4xl mx-auto pt-12 md:pt-16">
      <p
        class="font-sans text-base md:text-lg text-cream/80 leading-relaxed mb-6"
      >
        Welcome to the Quantum Biology DAO FAQ. This page is your guide to how
        our decentralized science community works: what quantum biology is, how
        our DAO funds and governs research, and how you can get involved.
        Whether you're coming from the science, the crypto space, or somewhere
        in between, this guide will walk you through the core ideas behind our
        community and how to participate.
      </p>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-3">
        <p class="font-sans text-base text-cream/80">
          If you want a full run-down, here's the place to go:
        </p>
        <Button href={explainerUrl} variant="primary" size="sm" external>
          Quantum Biology DAO Explainer
        </Button>
      </div>
    </div>
  </div>
</section>
