---
const cards = [
  {
    eyebrow: "01 — Community",
    title: "Welcoming Two New Scientists to the Quantum Biology Institute",
    body: "Two new scientists have joined the Quantum Biology Institute, bringing expertise in optical systems, molecular biology, and protein engineering to help build the experimental platforms behind next-generation quantum biology research.",
    image: "/images/graphics/qubie.webp",
    cta: "Read more",
    href: "#",
  },
  {
    eyebrow: "02 — Ecosystem",
    title: "Meet the Working Groups of the Quantum Biology DAO",
    body: "The Quantum Biology DAO is evolving its working group structure to support growth and invite broader community participation in building the future of decentralized science.",
    image: "/images/graphics/qubie.webp",
    cta: "Read more",
    href: "#",
  },
  {
    eyebrow: "03 — Research",
    title: "Bringing Quantum Biology to the World: Event Highlights",
    body: "The Quantum Biology team has been on the road this spring, sharing research and growing the DeSci movement at major events across Europe and the U.S.",
    image: "/images/graphics/qubie.webp",
    cta: "Read more",
    href: "#",
  },
];
---

<section class="bg-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2
      class="font-display text-2xl md:text-3xl text-plum-darkest text-center mb-14"
    >
      Latest updates from the Quantum Biology Ecosystem
    </h2>
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {
        cards.map((card) => (
          <article class="bg-paper rounded-2xl overflow-hidden shadow-sm flex flex-col">
            <div class={`aspect-[4/3] overflow-hidden ${card.imageBg ?? "bg-plum-darkest"}`}>
              <img
                src={card.image}
                alt=""
                class="w-full h-full object-cover object-left"
                loading="lazy"
              />
            </div>
            <div class="p-6 md:p-8 flex flex-col grow">
              <p class="font-sans text-xs tracking-[0.2em] uppercase text-mauve mb-3">
                {card.eyebrow}
              </p>
              <h3 class="font-display text-xl text-plum-darkest mb-3 leading-tight">
                {card.title}
              </h3>
              <p class="font-sans text-sm text-plum-darkest/70 mb-6 leading-relaxed grow">
                {card.body}
              </p>
              <a
                href={card.href}
                class="font-sans text-sm font-semibold text-plum-darkest underline underline-offset-4 hover:text-pink transition-colors"
              >
                {card.cta} →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
