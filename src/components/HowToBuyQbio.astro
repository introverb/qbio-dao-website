---
const steps = [
  { number: 1, label: "Create a wallet", icon: "wallet" },
  { number: 2, label: "Obtain ETH or SOL", icon: "coins" },
  { number: 3, label: "Choose your exchange", icon: "swap" },
  { number: 4, label: "Add & Hold $QBIO", icon: "vault" },
];

const ethAddress = "0x3e6a1b21bd267677fa49be6425aebe2fc0f89bde";
const solAddress = "qbioCGDnUBGX5qcK1Fc4zg19GaQEPmxHFMPMZQm4LZx";
---

<section id="how-to-buy" class="bg-paper text-plum-darkest py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2 class="font-display text-3xl md:text-4xl mb-10">How to buy QBIO</h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-14">
      {
        steps.map((s) => (
          <div class="relative aspect-[4/3] rounded-3xl border border-plum-darkest/15 bg-paper flex flex-col items-center justify-center gap-3 p-4 shadow-sm overflow-hidden hex-bg-light">
            <div class="relative text-plum-darkest">
              {s.icon === "wallet" && (
                <svg
                  width="84"
                  height="84"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" />
                  <path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
                  <path d="M18 12a2 2 0 0 0 0 4h4v-4z" />
                </svg>
              )}
              {s.icon === "coins" && (
                <svg
                  width="84"
                  height="84"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="9" cy="9" r="6" />
                  <path d="M16.5 9a6 6 0 1 1-6 9" />
                </svg>
              )}
              {s.icon === "swap" && (
                <svg
                  width="84"
                  height="84"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M16 3l4 4-4 4" />
                  <path d="M20 7H4" />
                  <path d="M8 21l-4-4 4-4" />
                  <path d="M4 17h16" />
                </svg>
              )}
              {s.icon === "vault" && (
                <svg
                  width="84"
                  height="84"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 9v-1" />
                  <path d="M12 16v-1" />
                </svg>
              )}
            </div>
            <p class="relative font-sans text-xs md:text-sm text-plum-darkest/70 text-center leading-tight">
              {s.label}
            </p>
          </div>
        ))
      }
    </div>

    <p
      class="font-sans text-base text-plum-darkest/80 mb-8 max-w-3xl leading-relaxed"
    >
      You can buy QBIO using either the Ethereum or Solana blockchain.
    </p>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
      <div>
        <h3 class="font-display text-xl text-plum-darkest mb-3">
          1. Create a wallet
        </h3>
        <ul class="space-y-1.5 font-sans text-sm text-plum-darkest/80">
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span><span class="font-semibold">Ethereum:</span> MetaMask</span>
          </li>
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span><span class="font-semibold">Solana:</span> Phantom</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-xl text-plum-darkest mb-3">
          2. Obtain ETH or SOL
        </h3>
        <ul class="space-y-1.5 font-sans text-sm text-plum-darkest/80">
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span
              >Buy ETH or SOL from an exchange such as Binance, Coinbase, or
              Kraken</span
            >
          </li>
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span>Send it to your wallet address</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-xl text-plum-darkest mb-3">
          3. Choose your exchange
        </h3>
        <div class="space-y-4">
          <div>
            <p class="font-sans text-sm font-semibold text-plum-darkest mb-1.5">
              Uniswap V3 on Ethereum
            </p>
            <ul class="space-y-1.5 font-sans text-sm text-plum-darkest/80">
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Connect MetaMask wallet to Uniswap</span>
              </li>
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Select ETH → QBIO pair</span>
              </li>
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Approve and swap</span>
              </li>
            </ul>
          </div>
          <div>
            <p class="font-sans text-sm font-semibold text-plum-darkest mb-1.5">
              Raydium on Solana
            </p>
            <ul class="space-y-1.5 font-sans text-sm text-plum-darkest/80">
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Use Phantom wallet</span>
              </li>
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Connect to Raydium and select SOL → QBIO</span>
              </li>
              <li class="flex gap-2">
                <span class="text-mauve">—</span>
                <span>Swap</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-display text-xl text-plum-darkest mb-3">
          4. Add & Hold Your $QBIO
        </h3>
        <ul class="space-y-1.5 font-sans text-sm text-plum-darkest/80">
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span>Ensure your QBIO tokens appear in your wallet</span>
          </li>
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span>Use the contract address to add it manually if needed</span>
          </li>
          <li class="flex gap-2">
            <span class="text-mauve">—</span>
            <span>Track with dashboards or portfolio apps</span>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 pt-8 border-t border-plum-darkest/10 max-w-4xl space-y-2"
    >
      <p class="font-display text-lg text-plum-darkest">Contract Addresses</p>
      <p class="font-sans text-sm text-plum-darkest/80">
        <span class="font-semibold">Ethereum:</span>
        <code class="font-mono text-xs break-all">{ethAddress}</code>
      </p>
      <p class="font-sans text-sm text-plum-darkest/80">
        <span class="font-semibold">Solana:</span>
        <code class="font-mono text-xs break-all">{solAddress}</code>
      </p>
    </div>
  </div>
</section>

<style>
  /* Honeycomb hex pattern with a dark plum stroke for use on the
     cream/paper step cards. Same geometry as the cream-stroke pattern
     on the governance phase panels — just inverted for light surfaces. */
  .hex-bg-light {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='42' height='73' viewBox='0 0 42 73'><path d='M21 13.875 L40.5 25.125 L40.5 47.625 L21 58.875 L1.5 47.625 L1.5 25.125 Z' fill='none' stroke='%2325101d' stroke-width='1.2' stroke-opacity='0.1'/></svg>");
    background-size: 42px 73px;
    background-position: center;
    background-repeat: repeat;
  }
</style>
