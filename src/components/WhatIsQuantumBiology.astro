---
const examples = [
  { label: "Photosynthesis", icon: "leaf" },
  { label: "Bird navigation", icon: "bird" },
  { label: "DNA repair", icon: "dna" },
  { label: "Magnetic sensitivity", icon: "magnet" },
  { label: "Sense of smell", icon: "nose" },
];
---

<section class="bg-plum-darkest text-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-[1fr_1.2fr] gap-10 lg:gap-14 mb-16">
      <div
        class="aspect-[4/3] rounded-3xl border border-cream/15 bg-plum-dark/30 flex items-center justify-center text-cream/30 self-start"
      >
        <svg
          width="72"
          height="72"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="1.5" fill="currentColor" />
          <ellipse cx="12" cy="12" rx="10" ry="4" />
          <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)" />
          <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(-60 12 12)" />
        </svg>
      </div>
      <div>
        <h2 class="font-display text-3xl md:text-4xl mb-6">
          What is quantum biology?
        </h2>
        <div
          class="space-y-5 font-sans text-base text-cream/80 leading-relaxed"
        >
          <p>
            Quantum biology is an emerging scientific field that explores how
            life depends on quantum phenomena.
          </p>
          <p>
            At its core, quantum biology studies how effects like superposition,
            electron spin, entanglement, or quantum tunneling can influence the
            molecules, cells, and systems of living organisms.
          </p>
          <p>
            While quantum effects are well-documented in physics and chemistry,
            biology has long been treated as "too messy" or "too warm" for
            these delicate phenomena. But this assumption is breaking down.
          </p>
          <p>Quantum biology challenges that view.</p>
        </div>
      </div>
    </div>

    <div
      class="rounded-3xl border border-cream/10 bg-plum-dark/20 p-6 md:p-10"
    >
      <h3 class="font-display text-xl md:text-2xl text-cream mb-8">
        Popular quantum biology examples:
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5">
      {
        examples.map((ex) => (
          <div class="flex flex-col">
            <div class="aspect-[4/3] rounded-2xl border border-cream/15 bg-plum-dark/30 flex items-center justify-center mb-4 text-cream/70">
              {ex.icon === "leaf" && (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M11 20A7 7 0 0 1 4 13c0-2 1-3.9 3-5.5C9 5.5 13 4 17 3c1 5-2 12-6 17z" />
                  <path d="M2 22c4-2 7-5 9-9" />
                </svg>
              )}
              {ex.icon === "bird" && (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M16 7h.01" />
                  <path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20" />
                  <path d="m20 7 2 .5-2 .5" />
                  <path d="M10 18v3" />
                  <path d="M14 17.75V21" />
                  <path d="M7 18a6 6 0 0 0 3.84-10.61" />
                </svg>
              )}
              {ex.icon === "dna" && (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 2c0 7 8 8 8 14s-8 7-8 6" />
                  <path d="M20 2c0 7-8 8-8 14s8 7 8 6" />
                  <path d="M6 6h12" />
                  <path d="M8 10h8" />
                  <path d="M8 14h8" />
                  <path d="M6 18h12" />
                </svg>
              )}
              {ex.icon === "magnet" && (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M6 15a6 6 0 0 0 12 0V3h-4v12a2 2 0 0 1-4 0V3H6z" />
                  <path d="M6 8h4" />
                  <path d="M14 8h4" />
                </svg>
              )}
              {ex.icon === "nose" && (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 3v9" />
                  <path d="M12 12c-2 0-4 1.5-4 3.5S10 19 12 19s4-1.5 4-3.5-2-3.5-4-3.5z" />
                  <path d="M8 19a4 4 0 0 0 8 0" />
                </svg>
              )}
            </div>
            <p class="font-sans text-sm text-cream/85 text-center">
              {ex.label}
            </p>
          </div>
        ))
      }
      </div>
    </div>
  </div>
</section>
