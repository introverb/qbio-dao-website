---
import V2Layout from "../components/v2/V2Layout.astro";
import V2Cta from "../components/v2/V2Cta.astro";
import EyebrowLabel from "../components/v2/EyebrowLabel.astro";
import { bentoCard, bentoHeading } from "../lib/v2-bg";

// --- Governance phases ----------------------------------------------------
const phases = [
  {
    number: 1,
    title: "Drafting",
    duration: "Varies",
    tool: "Discord",
    icon: "draft",
    body: "New proposals are introduced in the governance-proposal channel on Discord, where early-stage ideas are shared and discussed. Proposals may be made by any Quantum Biology DAO community member, including members of the Quantum Biology DAO team. Proposals in this phase are flexible in format and designed to promote open dialogue. A proposal advances to Phase 2 if it receives a minimum of five upvotes, with at least two from Quantum Biology DAO Core Contributors.",
  },
  {
    number: 2,
    title: "Community Voting",
    duration: "1/3/7 Days",
    tool: "Commonwealth",
    icon: "community",
    body: "Proposals that pass Phase 1 advance to Common for further discussion and community voting. Voting in Phase 2 requires participants to hold at least 10,000 QBIO, the DAO's governance token. If, by the end of the discussion period, a proposal gets ten or more votes with a majority in favor, it moves to the final stage, Phase 3. Otherwise, it returns to Phase 1 discussion on Discord or is dropped.",
  },
  {
    number: 3,
    title: "Token Voting",
    duration: "1/3/7 Days",
    tool: "Snapshot",
    icon: "token",
    body: "Final-stage voting is open to all holders of the DAO's governance token. Token holders may assign their voting power to a delegate of their choice from within the community. Proposals must meet a 3% quorum and a simple majority of total votes in favor to pass. A proposal is considered unsuccessful if it does not achieve either the required quorum or simple majority in favor. The Association reserves the right to act before the voting period concludes if the outcome is decisively clear.",
  },
];

// --- Progressive decentralization principles ------------------------------
const principles = [
  { label: "Resilience", body: "No single person or institution controls the DAO" },
  { label: "Inclusivity", body: "Scientists, engineers, students, and supporters all have a voice" },
  { label: "Scalability", body: "Governance evolves as the ecosystem grows" },
];

// --- Why buy QBIO reasons -------------------------------------------------
const reasons = [
  {
    title: "Vote on real scientific decisions",
    body: "Each QBIO token represents a vote. When you hold QBIO, you help decide which research we support and which tools we develop.",
    icon: "vote",
  },
  {
    title: "Support decentralized science",
    body: "QBIO helps create an open, transparent system for conducting science. This makes research more accessible and less dependent on institutions with narrow priorities.",
    icon: "network",
  },
  {
    title: "Build shared scientific infrastructure",
    body: "QBIO holders help fund new technologies, experiments, and open tools that benefit the entire ecosystem and beyond.",
    icon: "blocks",
  },
];

// --- How to buy steps -----------------------------------------------------
const steps = [
  { number: 1, label: "Create a wallet", icon: "wallet" },
  { number: 2, label: "Obtain ETH or SOL", icon: "coins" },
  { number: 3, label: "Choose your exchange", icon: "swap" },
  { number: 4, label: "Add & Hold $QBIO", icon: "vault" },
];

const ethAddress = "0x3e6a1b21bd267677fa49be6425aebe2fc0f89bde";
const solAddress = "qbioCGDnUBGX5qcK1Fc4zg19GaQEPmxHFMPMZQm4LZx";

// --- Governance testimonials ----------------------------------------------
const testimonials = [
  {
    quote:
      "The DAO is letting us explore new governance methods in science. It's very exciting.",
    author: "Geoff Anders",
    role: "Quantum Biology DAO Co-Founder",
  },
  {
    quote:
      "Governance matters because it gives every member a real voice in shaping the future of quantum biology. I value the token as more than an asset, it's a tool for participation and accountability. Voting on proposals makes me feel like I'm not just a supporter, but a co-creator of this DAO.",
    author: "Zicjoe",
    role: "DAO Community Member",
  },
  {
    quote:
      "I joined because I'm fascinated by the interface between matter and mind, and also because I wanted to witness first hand and participate in the creation of an entire new ecosystem, that runs using a new logic of incentivization.",
    author: "Panetone",
    role: "DAO Community Member",
  },
];

// --- Tokenomics donut math (kept from v1) ---------------------------------
const slices = [
  { label: "Core team", value: 20, color: "#4b243c" },
  { label: "Service providers", value: 7, color: "#5c2d49" },
  { label: "Community auction", value: 15, color: "#854b6e" },
  { label: "Community incentives", value: 3, color: "#d57db2" },
  { label: "Treasury", value: 55, color: "#ffceec" },
];
const _cx = 240;
const _cy = 200;
const _rO = 110;
const _rI = 65;
const _labelGap = 35;
let _acc = -Math.PI / 2;
const computedSlices = slices.map((s) => {
  const a1 = _acc;
  const a2 = _acc + (s.value / 100) * 2 * Math.PI;
  _acc = a2;
  const mid = (a1 + a2) / 2;
  const sx = _cx + _rO * Math.cos(a1);
  const sy = _cy + _rO * Math.sin(a1);
  const ex = _cx + _rO * Math.cos(a2);
  const ey = _cy + _rO * Math.sin(a2);
  const sxi = _cx + _rI * Math.cos(a2);
  const syi = _cy + _rI * Math.sin(a2);
  const exi = _cx + _rI * Math.cos(a1);
  const eyi = _cy + _rI * Math.sin(a1);
  const large = a2 - a1 > Math.PI ? 1 : 0;
  const path = `M ${sx} ${sy} A ${_rO} ${_rO} 0 ${large} 1 ${ex} ${ey} L ${sxi} ${syi} A ${_rI} ${_rI} 0 ${large} 0 ${exi} ${eyi} Z`;
  const lineStartX = _cx + _rO * Math.cos(mid);
  const lineStartY = _cy + _rO * Math.sin(mid);
  const labelX = _cx + (_rO + _labelGap) * Math.cos(mid);
  const labelY = _cy + (_rO + _labelGap) * Math.sin(mid);
  const anchor = Math.cos(mid) > 0 ? "start" : "end";
  const textOffset = anchor === "start" ? 5 : -5;
  return { ...s, path, lineStartX, lineStartY, labelX, labelY, textX: labelX + textOffset, anchor };
});
---

<V2Layout
  title="QBIO Token — Quantum Biology DAO"
  description="QBIO is the governance token of the Quantum Biology DAO. Learn how decisions are made and how to buy QBIO."
>
  <!-- ====================================================================== -->
  <!-- HERO  —  coin video bleeds from upper-right, title on the left          -->
  <!-- ====================================================================== -->
  <section class="relative pb-16 md:pb-24">
    <!-- Coin video — anchored top-right. NOTE: no transform on this wrapper
         (transforms create an isolated stacking context that breaks
         mix-blend-screen on the video, leaving the video's black bg visible).
         Positioning via scoped style block below because Tailwind 4's JIT
         was unreliable about generating arbitrary width / right utilities. -->
    <div
      class="coin-hero-wrap relative pt-20 lg:pt-0 lg:absolute lg:top-0 pointer-events-none"
    >
      <video
        class="block w-full max-w-none aspect-square object-contain mix-blend-screen saturate-[1.5] contrast-[1.2] scale-y-[0.95]"
        autoplay
        loop
        muted
        playsinline
        aria-label="QBIO governance token, slowly spinning"
      >
        <source src="/images/graphics/qbiotokengif.mp4" type="video/mp4" />
        <img
          src="/images/graphics/QBIOTOKEN.png"
          alt="QBIO governance token"
          class="w-full h-auto"
        />
      </video>
    </div>

    <!-- Title block -->
    <div
      class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-8 lg:pt-32 z-10"
    >
      <div class="lg:max-w-[58%]">
        <EyebrowLabel accent="gold">Governance</EyebrowLabel>
        <h1
          class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5rem] leading-[0.95] tracking-tight text-cream"
        >
          How we make
          <span class="block">
            decisions
            <em class="italic text-gold/90">together</em>
          </span>
          <span class="block">to advance quantum biology.</span>
        </h1>
        <p
          class="mt-8 font-sans text-[14px] text-cream/65 leading-relaxed max-w-md"
        >
          The Quantum Biology DAO is a decentralized organization that supports
          open scientific research at the frontier of biology and physics.
          Instead of relying on a central leader or institution, decisions are
          made collectively — and at the center of that process is QBIO, the
          governance token that powers the DAO.
        </p>
        <div class="mt-10 flex flex-col items-start gap-5">
          <V2Cta href="#what-is-qbio" label="Learn about QBIO" accent="gold" />
          <V2Cta href="#how-to-buy" label="How to buy QBIO" accent="pink" />
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- BENTO REGION                                                            -->
  <!-- ====================================================================== -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-6 lg:gap-7 auto-rows-auto">

      <!-- ============================================================= -->
      <!-- WHY GOVERNANCE                                          PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">Why governance</EyebrowLabel>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
          <div class="lg:col-span-6">
            <h2 class={bentoHeading}>
              Why is governance
              <span class="block">
                important for <em class="italic text-pink/90">science</em>?
              </span>
            </h2>
          </div>
          <div
            class="lg:col-span-6 font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              In traditional science, only a powerful few decide what gets
              researched. The Quantum Biology DAO is building something
              different: a global, community-led system where anyone can help
              guide scientific discovery.
            </p>
            <p>
              By distributing decision-making power through the QBIO token, we
              enable researchers, engineers, students, and supporters worldwide
              to work together to fund meaningful experiments and build shared
              scientific infrastructure.
            </p>
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- HOW GOVERNANCE WORKS — 3 phases                         PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">The process</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-6 max-w-3xl`}>
          How governance works:
          <em class="italic text-pink/90">3 simple phases</em>.
        </h2>
        <p
          class="font-sans text-[14px] text-cream/70 leading-relaxed max-w-3xl mb-10"
        >
          The Quantum Biology DAO governance process is structured into three
          progressive phases, each designed to guide proposals from ideation to
          implementation.
        </p>
        <div class="grid md:grid-cols-3 gap-5 md:gap-6">
          {
            phases.map((p) => (
              <div class="flex flex-col rounded-lg border border-cream/10 bg-plum-deepest/40 p-5 md:p-6">
                <div class="aspect-[3/2] rounded-md bg-mauve/30 flex items-center justify-center mb-5 text-cream/85">
                  {p.icon === "draft" && (
                    <svg
                      width="80"
                      height="80"
                      viewBox="0 0 64 64"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M14 12 L50 12 Q54 12 54 16 L54 40 Q54 44 50 44 L36 44 L28 52 L28 44 L14 44 Q10 44 10 40 L10 16 Q10 12 14 12 Z" />
                      <circle cx="24" cy="28" r="1.6" fill="currentColor" stroke="none" />
                      <circle cx="32" cy="28" r="1.6" fill="currentColor" stroke="none" />
                      <circle cx="40" cy="28" r="1.6" fill="currentColor" stroke="none" />
                    </svg>
                  )}
                  {p.icon === "community" && (
                    <svg
                      width="80"
                      height="80"
                      viewBox="0 0 64 64"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polygon points="32,6 42,12 42,24 32,30 22,24 22,12" />
                      <polygon points="16,30 26,36 26,48 16,54 6,48 6,36" />
                      <polygon points="48,30 58,36 58,48 48,54 38,48 38,36" />
                      <line x1="27" y1="27" x2="21" y2="33" />
                      <line x1="37" y1="27" x2="43" y2="33" />
                    </svg>
                  )}
                  {p.icon === "token" && (
                    <svg
                      width="80"
                      height="80"
                      viewBox="0 0 64 64"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polygon points="32,6 54,18 54,46 32,58 10,46 10,18" />
                      <polygon points="32,15 46,23 46,41 32,49 18,41 18,23" stroke-opacity="0.35" />
                      <polyline points="24,32 30,38 41,26" />
                    </svg>
                  )}
                </div>
                <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-pink/70 mb-2">
                  Phase {p.number}
                </p>
                <h3 class="font-display text-xl text-cream mb-3 leading-tight">
                  {p.title}
                </h3>
                <div class="font-sans text-[11px] text-cream/55 mb-4 space-y-0.5">
                  <p>
                    <span class="text-cream/70">Duration:</span> {p.duration}
                  </p>
                  <p>
                    <span class="text-cream/70">Tool:</span> {p.tool}
                  </p>
                </div>
                <p class="font-sans text-[13px] text-cream/70 leading-relaxed">
                  {p.body}
                </p>
              </div>
            ))
          }
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- PROGRESSIVE DECENTRALIZATION                            GOLD   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="gold">Long-term direction</EyebrowLabel>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
          <div class="lg:col-span-5">
            <h2 class={bentoHeading}>
              Progressive
              <em class="italic text-gold/90">decentralization</em>.
            </h2>
          </div>
          <div class="lg:col-span-7">
            <div
              class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4 mb-8"
            >
              <p>
                Though originally founded by three people, the Quantum Biology
                DAO was designed with progressive decentralization as an
                intentional goal.
              </p>
              <p>
                Over time, governance power will shift from the founding team
                to the broader community. This ensures:
              </p>
            </div>
            <ul class="space-y-3 mb-8">
              {
                principles.map((p) => (
                  <li class="flex gap-4 items-start font-sans text-[14px] text-cream/80">
                    <span class="text-gold/70 mt-1 shrink-0">—</span>
                    <span>
                      <span class="font-semibold text-cream">{p.label}:</span>{" "}
                      {p.body}
                    </span>
                  </li>
                ))
              }
            </ul>
            <p
              class="font-sans text-[14px] text-cream/70 leading-relaxed mb-10"
            >
              This is how we build toward a truly global, community-owned
              system for advancing open science.
            </p>
            <V2Cta
              href="https://saurikz.com/what-is-progressive-decentralization-web3"
              label="Read more"
              accent="gold"
              external
            />
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- WHAT IS QBIO + WHY BUY                                  TEAL   -->
      <!-- ============================================================= -->
      <article id="what-is-qbio" class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="teal">The token</EyebrowLabel>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 mb-16">
          <div class="lg:col-span-6">
            <h2 class={bentoHeading}>
              What are tokens?
              <span class="block">
                What is the <em class="italic text-teal/90">QBIO token</em>?
              </span>
            </h2>
          </div>
          <div
            class="lg:col-span-6 font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              A token is a digital asset that allows people to participate in a
              decentralized system. In our case, the QBIO token is a governance
              token of the Quantum Biology DAO.
            </p>
            <p>
              Holding QBIO means you are part of the decision-making process:
              you can propose ideas, vote on proposals, and help shape the
              DAO's activities, including funding research, managing community
              initiatives, and setting strategic priorities.
            </p>
            <p>
              By participating, QBIO holders collectively advance quantum
              biology as an open, community-led field.
            </p>
          </div>
        </div>

        <div class="border-t border-cream/10 pt-10">
          <p
            class="font-sans text-[11px] tracking-[0.3em] uppercase text-teal mb-6"
          >
            Why buy QBIO
          </p>
          <h3 class="font-display text-2xl md:text-3xl text-cream tracking-tight mb-10">
            Three reasons to <em class="italic text-teal/90">hold</em>.
          </h3>
          <div class="grid md:grid-cols-3 gap-5 md:gap-6">
            {
              reasons.map((r, i) => (
                <div class="flex flex-col rounded-lg border border-cream/10 bg-plum-deepest/40 p-6 md:p-7">
                  <div class="text-teal/80 mb-5">
                    {r.icon === "vote" && (
                      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 12l2 2 4-4" />
                        <path d="M21 12c0 5-3.5 7.5-9 7.5S3 17 3 12s3.5-7.5 9-7.5 9 2.5 9 7.5z" />
                      </svg>
                    )}
                    {r.icon === "network" && (
                      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="5" r="2" />
                        <circle cx="5" cy="19" r="2" />
                        <circle cx="19" cy="19" r="2" />
                        <circle cx="12" cy="13" r="2" />
                        <path d="M12 7v4" />
                        <path d="M6.5 17.5l4-2.5" />
                        <path d="M17.5 17.5l-4-2.5" />
                      </svg>
                    )}
                    {r.icon === "blocks" && (
                      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="8" height="8" rx="1" />
                        <rect x="13" y="3" width="8" height="8" rx="1" />
                        <rect x="3" y="13" width="8" height="8" rx="1" />
                        <rect x="13" y="13" width="8" height="8" rx="1" />
                      </svg>
                    )}
                  </div>
                  <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-teal/60 mb-2">
                    {String(i + 1).padStart(2, "0")}
                  </p>
                  <h4 class="font-display text-lg md:text-xl text-cream leading-tight mb-3">
                    {r.title}
                  </h4>
                  <p class="font-sans text-[13px] text-cream/65 leading-relaxed">
                    {r.body}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- TOKENOMICS                                              TEAL   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="teal">Tokenomics</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          QBIO <em class="italic text-teal/90">allocation</em>.
        </h2>
        <div class="bg-paper rounded-lg p-6 md:p-10 max-w-3xl mx-auto">
          <svg
            viewBox="0 0 540 400"
            preserveAspectRatio="xMidYMid meet"
            width="540"
            height="400"
            class="max-w-full h-auto block"
            role="img"
            aria-labelledby="tokenomics-title-v2"
          >
            <title id="tokenomics-title-v2">QBIO token allocation</title>
            {computedSlices.map((s) => <path d={s.path} fill={s.color} />)}
            <image
              href="/images/brand/logo-mark.png"
              x={_cx - 38}
              y={_cy - 38}
              width="76"
              height="76"
              preserveAspectRatio="xMidYMid meet"
            />
            {
              computedSlices.map((s) => (
                <g>
                  <line x1={s.lineStartX} y1={s.lineStartY} x2={s.labelX} y2={s.labelY} stroke="#25101d" stroke-width="1" />
                  <circle cx={s.lineStartX} cy={s.lineStartY} r="2" fill="#25101d" />
                  <text x={s.textX} y={s.labelY - 3} text-anchor={s.anchor} font-family="Apercu, system-ui, sans-serif" font-size="13" fill="#25101d">
                    {s.label}
                  </text>
                  <text x={s.textX} y={s.labelY + 12} text-anchor={s.anchor} font-family="Apercu, system-ui, sans-serif" font-size="13" fill="#25101d">
                    {s.value}%
                  </text>
                </g>
              ))
            }
          </svg>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- HOW TO BUY                                              PINK   -->
      <!-- ============================================================= -->
      <article id="how-to-buy" class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">Get started</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          How to <em class="italic text-pink/90">buy QBIO</em>.
        </h2>

        <!-- Step icon strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          {
            steps.map((s) => (
              <div class="aspect-[4/3] rounded-lg border border-cream/10 bg-plum-deepest/40 flex flex-col items-center justify-center gap-4 p-4">
                <div class="text-pink/80">
                  {s.icon === "wallet" && (
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" />
                      <path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
                      <path d="M18 12a2 2 0 0 0 0 4h4v-4z" />
                    </svg>
                  )}
                  {s.icon === "coins" && (
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="9" cy="9" r="6" />
                      <path d="M16.5 9a6 6 0 1 1-6 9" />
                    </svg>
                  )}
                  {s.icon === "swap" && (
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M16 3l4 4-4 4" />
                      <path d="M20 7H4" />
                      <path d="M8 21l-4-4 4-4" />
                      <path d="M4 17h16" />
                    </svg>
                  )}
                  {s.icon === "vault" && (
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="5" width="18" height="14" rx="2" />
                      <circle cx="12" cy="12" r="3" />
                      <path d="M12 9v-1" />
                      <path d="M12 16v-1" />
                    </svg>
