  /* Right offset chosen so the coin's center sits ~79% across the viewport
     — i.e. visually centered between the text column (which ends around
     58%) and the right edge of the page. */
  @media (min-width: 1024px) {
    .coin-hero-wrap {
      width: 27.5%;
      right: 7%;
      top: 16rem;
    }
  }
