---
import V2Layout from "../components/v2/V2Layout.astro";
import V2Cta from "../components/v2/V2Cta.astro";
import EyebrowLabel from "../components/v2/EyebrowLabel.astro";
import { bentoCard, bentoHeading } from "../lib/v2-bg";

const activities = [
  "Fund research",
  "Share knowledge",
  "Build tools",
  "Grow awareness about quantum biology",
];

const joinBullets = [
  "Introduce yourself in the #introductions channel.",
  "Follow channels that interest you and join discussions as you feel comfortable.",
  "Attend our weekly community calls to hear updates and contribute to DAO progress.",
];

const workingGroups = [
  {
    name: "Science",
    description:
      "Reviewing papers, developing and discussing hypotheses, contributing to scientific roadmaps, helping determine priorities for grants to scientists, and advising the DAO on the science-related matters.",
    icon: "atom",
  },
  {
    name: "Communications",
    description:
      "Managing social media, maintaining community engagement, responding to general queries, deleting spam, enforcing community standards, educating people about quantum biology and the Quantum Biology DAO, and more.",
    icon: "chat",
  },
  {
    name: "Operations",
    description:
      "Tracking community member contributions, helping with scheduling, maintaining compliance with laws, and more.",
    icon: "cog",
  },
  {
    name: "Treasury",
    description:
      "Managing the DAO's treasury, overseeing token allocations, tracking grant disbursement, and maintaining financial transparency for the community.",
    icon: "wallet",
  },
  {
    name: "Product",
    description:
      "Developing products (e.g., scientific instruments) for the DAO to sell, identifying potential customers, creating marketing and distribution plans, perform market analyses to identify opportunities for products, and more.",
    icon: "product",
  },
];

// Mirrors the home-v2 team data — Founder titles for Clarice/Geoff/Ale,
// Kyra as Media Director, Mike removed pending finalisation.
const contributors = [
  {
    name: "Dr. Clarice D. Aiello",
    role: "Founder",
    img: "/images/team/clarice.jpeg",
    bio: "Clarice is a quantum engineer interested in how quantum physics informs biology at the nanoscale. Born and raised in Brazil, Clarice obtained a Diplome d'Ingenieur in Physics from the Ecole Polytechnique in France and an M.Phil. in Physics from the University of Cambridge, Trinity College, in England; she received her Ph.D. from MIT in Electrical Engineering. She further held postdoctoral appointments in Bioengineering at Stanford, and in Chemistry at Berkeley.",
  },
  {
    name: "Dr. Geoff Anders",
    role: "Founder",
    img: "/images/team/geoff.jpeg",
    bio: "Geoff Anders is the founder and CEO of Leverage, a research institute established in 2011 to support revolutionary scientific research. With a background in philosophy and social science, he leads Leverage's internal research and helps external research teams organize to make important scientific breakthroughs. His recent work focuses on the intersection of philosophy, science, and history, as it pertains especially to introspection, cognitive science, and artificial intelligence. Geoff is now the CEO of the Quantum Biology Institute and holds a PhD in Philosophy from Rutgers University and a BS in Economics from the Wharton School at the University of Pennsylvania.",
  },
  {
    name: "Dr. Alessandro Lodesani",
    role: "Founder",
    img: "/images/team/ale.jpeg",
    bio: "Alessandro Lodesani is the Institute's Chief Operating Officer, overseeing its daily research operations. With a strong background in physics and engineering, combined with extensive experience in biology research, Alessandro focuses on designing innovative devices and optimizing lab processes. Originally from Italy, Alessandro earned a Bachelor's in Mechanical Engineering and a PhD in Physics, graduating with honors from the Polytechnic University of Milan, with a specialization in spintronics and molecular interfaces. His previous research at MIT focused on topological qubits and superconducting thin films, where he successfully developed the world's most efficient superconducting diode platform. Alessandro then joined the Institute in its early days at UCLA, where he led several projects investigating the influence of weak magnetic fields on biological systems.",
  },
  {
    name: "Jennilyn Gaitan",
    role: "Operations",
    img: "/images/team/jen.jpeg",
    bio: "Jennilyn Gaitan graduated with a Bachelor of Science in Electronic Media and Film from Towson University. Since 2004, she has worked in various administrative and operational roles across multiple industries, including retail, higher education, photography, real estate, and small business operations. Jennilyn has a passion for creating and refining the systems and processes that businesses use, to run most efficiently, which has been a hallmark of her career. In November 2023, Jennilyn joined the Quantum Biology Institute, contributing her expertise to the administration and operations of the Institute.",
  },
  {
    name: "Kyra Gardner",
    role: "Media Director",
    img: "/images/team/kyra.jpeg",
    bio: "Kyra Gardner is the Communications Working Group Leader for the Quantum Biology DAO, where she manages communications and social media. She joined the DAO in January of 2025 and carries out this work through Smarter with Science, a company she co-founded whose team members are also deeply involved in the quantum biology ecosystem. Despite not having as technical of a science background as some of her DAO peers, she enjoys finding ways to connect complex topics to everyday life and make them accessible to broader audiences.",
  },
];

const testimonials = [
  {
    quote:
      "Being part of the Quantum DAO community means building with people who believe science should be open and collective. I contribute because collaboration here feels like belonging to something bigger than myself, and through this DAO I've connected with people I never would have met, which makes the work feel alive.",
    author: "Zicjoe",
    role: "DAO Community Member",
  },
  {
    quote:
      "What makes this DAO special is the mix of science, community, and shared ownership. It's rare to see governance, research, and passion aligned, this DAO manages to hold all three. This isn't just a community; it's a movement to change how science is funded and shared.",
    author: "Zicjoe",
    role: "DAO Community Member",
  },
  {
    quote:
      "Quantum Biology DAO represents an important advancement in decentralized science, opening doors for new, lesser-known possibilities, such as how weak magnetic fields could impact DNA repair for longevity, blood viscosity, and many more unknowns. I'm thrilled to be part of the community and excited for the journey ahead.",
    author: "Timmygram",
    role: "DAO Community Member",
  },
  {
    quote:
      "I joined because I believe scientists are the one uplifting our society so that all humans can advance.",
    author: "Misery",
    role: "DAO Community Member",
  },
];
---

<V2Layout
  title="Community — Quantum Biology DAO"
  description="How to contribute to the Quantum Biology DAO — join the community, get involved with a working group, and participate in governance."
>
  <!-- ====================================================================== -->
  <!-- HERO  —  chain graphic anchored top-right, title on the left           -->
  <!-- ====================================================================== -->
  <section class="relative pb-16 md:pb-24">
    <!-- Chain graphic — enters from upper-right corner -->
    <div
      class="relative pt-20 lg:pt-0 lg:absolute lg:top-0 lg:right-0 lg:w-[55%] xl:w-[48%] pointer-events-none community-hero-chain"
    >
      <img
        src="/images/graphics/chain.png"
        alt=""
        class="block w-full max-w-none"
        loading="eager"
      />
    </div>

    <!-- Title block -->
    <div
      class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-8 lg:pt-32 z-10"
    >
      <div class="lg:max-w-[58%]">
        <EyebrowLabel accent="gold">Community</EyebrowLabel>
        <h1
          class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5rem] leading-[0.95] tracking-tight text-cream"
        >
          How to
          <em class="italic text-gold/90">contribute</em>
          <span class="block">
            to the Quantum Biology DAO.
          </span>
        </h1>
        <p
          class="mt-8 font-sans text-[14px] text-cream/65 leading-relaxed max-w-md"
        >
          At the Quantum Biology DAO, we're building a global community dedicated
          to advancing quantum biology through open collaboration, decentralized
          decision-making, and shared purpose. Whether you're a scientist,
          technologist, educator, or simply curious about this emerging field,
          you're welcome here.
        </p>
        <div class="mt-10 flex flex-col items-start gap-5">
          <V2Cta
            href="https://quantumbiology.community"
            label="Join our Discord"
            accent="gold"
            external
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- BENTO REGION                                                            -->
  <!-- ====================================================================== -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-6 lg:gap-7 auto-rows-auto">

      <!-- ============================================================= -->
      <!-- WHAT IS THE COMMUNITY                                   PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">About</EyebrowLabel>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 mb-10">
          <div class="lg:col-span-6">
            <h2 class={bentoHeading}>
              What is the Quantum Biology
              <em class="italic text-pink/90">DAO community</em>?
            </h2>
          </div>
          <div
            class="lg:col-span-6 font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              The Quantum Biology community is a decentralized group of people
              (ranging from enthusiasts to quantum physicists) working at the
              intersection of quantum physics and biology.
            </p>
            <p>
              We're organized as a DAO (Decentralized Autonomous Organization),
              which means our work is driven by the community, not by a single
              leader or company. Members come together to:
            </p>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mb-8">
          {
            activities.map((label) => (
              <span class="px-5 py-2 rounded-full border border-pink/40 text-cream font-sans text-[13px]">
                {label}
              </span>
            ))
          }
        </div>

        <p
          class="font-sans text-[14px] text-cream/70 leading-relaxed max-w-3xl"
        >
          Through open collaboration and blockchain-based governance, we're
          creating a space where anyone can contribute to the future of
          science.{" "}
          <a
            href="/qbio-token"
            class="text-pink hover:text-pink-light underline underline-offset-2"
          >
            Learn more about the governance process here
          </a>.
        </p>
      </article>

      <!-- ============================================================= -->
      <!-- JOIN THE CONVERSATION                                   GOLD   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="gold">First step</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          Join the <em class="italic text-gold/90">conversation</em>.
        </h2>

        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
          <div class="lg:col-span-5">
            <V2Cta
              href="https://quantumbiology.community"
              label="Join our Discord"
              accent="gold"
              external
            />
          </div>
          <div class="lg:col-span-7">
            <ul class="space-y-4 font-sans text-[14px] text-cream/75 leading-relaxed">
              {
                joinBullets.map((b) => (
                  <li class="flex gap-4 items-start">
                    <span class="text-gold/70 mt-1 shrink-0">—</span>
                    <span>{b}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- WORKING GROUPS                                          PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">Get involved</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-6 max-w-3xl`}>
          Pick a <em class="italic text-pink/90">working group</em>.
        </h2>
        <p
          class="font-sans text-[14px] text-cream/70 leading-relaxed max-w-3xl mb-10"
        >
          Our working groups are where most of the collaboration happens. You
          can listen in, share ideas, or volunteer when you're ready. Currently
          we have five main groups:
        </p>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5 md:gap-6"
        >
          {
            workingGroups.map((g, i) => (
              <div class="flex flex-col rounded-lg border border-cream/10 bg-plum-deepest/40 p-5 md:p-6">
                <div class="text-pink/80 mb-5">
                  {g.icon === "atom" && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="1.2" fill="currentColor" />
                      <path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5Z" />
                      <path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5Z" />
                    </svg>
                  )}
                  {g.icon === "chat" && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                    </svg>
                  )}
                  {g.icon === "cog" && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="3" />
                      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
                    </svg>
                  )}
                  {g.icon === "wallet" && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" />
                      <path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
                      <path d="M18 12a2 2 0 0 0 0 4h4v-4z" />
                    </svg>
                  )}
                  {g.icon === "product" && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                      <line x1="12" y1="22.08" x2="12" y2="12" />
                    </svg>
                  )}
                </div>
                <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-pink/60 mb-2">
                  {String(i + 1).padStart(2, "0")}
                </p>
                <h3 class="font-display text-lg md:text-xl text-cream mb-3 leading-tight">
                  {g.name}
                </h3>
                <p class="font-sans text-[12px] text-cream/65 leading-relaxed">
                  {g.description}
                </p>
              </div>
            ))
          }
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- PARTICIPATE IN GOVERNANCE                               TEAL   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="teal">Have a voice</EyebrowLabel>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
          <div class="lg:col-span-6">
            <h2 class={`${bentoHeading} mb-6`}>
              Participate in
              <em class="italic text-teal/90">governance</em>.
            </h2>
            <p
              class="font-sans text-[14px] text-cream/70 leading-relaxed mb-10 max-w-md"
            >
              As a DAO, we make decisions together. You can follow proposals,
              join discussions, and vote if you hold QBIO tokens.
            </p>
          </div>
          <div class="lg:col-span-6 flex flex-col items-start gap-5 lg:pt-12">
            <V2Cta
              href="/qbio-token"
              label="How governance works"
              accent="teal"
            />
            <V2Cta
              href="/qbio-token#what-is-qbio"
              label="About the QBIO token"
              accent="gold"
            />
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- CORE CONTRIBUTORS                                       GOLD   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="gold">Core contributors</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          The people <em class="italic text-gold/90">behind</em> the DAO.
        </h2>
        <div
          class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-10"
        >
          {
            contributors.map((c, i) => (
              <button
                type="button"
                data-bio-trigger={`community-${i}`}
                class="group flex flex-col items-center text-center p-4 -m-4 rounded-2xl bg-transparent hover:bg-pink/10 transition-colors cursor-pointer outline-none appearance-none border-0 focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-plum-darkest"
                aria-haspopup="dialog"
                aria-controls={`bio-community-${i}`}
              >
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden bg-plum-deepest mb-4 ring-1 ring-cream/10 group-hover:ring-gold transition">
                  <img
                    src={c.img}
                    alt={c.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="font-sans font-semibold text-sm text-cream mb-1">
                  {c.name}
                </h3>
                <p class="font-sans text-[10px] uppercase tracking-[0.18em] text-gold mb-3">
                  {c.role}
                </p>
                <span class="font-sans text-[10px] tracking-[0.18em] uppercase text-gold/70 group-hover:text-pink-light transition-colors">
                  Read bio →
                </span>
              </button>
            ))
          }
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- VOICES (Community testimonials)                         PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">Voices</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          From the <em class="italic text-pink/90">community</em>.
        </h2>
        <div class="grid md:grid-cols-2 gap-5 md:gap-6">
          {
            testimonials.map((t) => (
              <div class="flex flex-col rounded-lg border border-cream/10 bg-plum-deepest/40 p-6 md:p-7">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-pink/60 mb-5" aria-hidden="true">
                  <path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z" />
                </svg>
                <p class="font-display text-base md:text-lg text-cream/90 leading-snug mb-6 flex-grow">
                  {t.quote}
                </p>
                <div class="border-t border-cream/10 pt-4">
                  <p class="font-sans text-cream font-semibold text-sm">
                    {t.author}
                  </p>
                  <p class="font-sans text-cream/50 text-[11px] mt-1 tracking-wide uppercase">
                    {t.role}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </div>

  <!-- ====================================================================== -->
  <!-- QUESTIONS                                                              -->
  <!-- ====================================================================== -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <EyebrowLabel accent="gold" class="mb-8">Questions</EyebrowLabel>
      <h2
        class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.05] tracking-tight text-cream mb-10"
      >
        Still have <em class="italic text-gold/90">questions</em>?
      </h2>
      <div class="inline-flex">
        <V2Cta href="/faqs" label="See all FAQs" accent="gold" />
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- Bio dialogs (modal popups, one per core contributor)                   -->
  <!-- ====================================================================== -->
  {
    contributors.map((c, i) => (
      <dialog
        id={`bio-community-${i}`}
        class="bio-dialog p-0 rounded-lg bg-plum-darkest text-cream max-w-2xl w-[92vw] m-auto border border-cream/10"
      >
        <div class="relative p-8 md:p-10">
          <button
            type="button"
            data-bio-close
            aria-label="Close"
            class="absolute top-4 right-4 p-2 rounded-full text-cream/50 hover:text-cream hover:bg-cream/5 transition-colors"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
          <div class="flex flex-col sm:flex-row sm:items-center gap-5 mb-6 pr-8">
            <div class="w-20 h-20 shrink-0 rounded-full overflow-hidden bg-plum-deepest ring-1 ring-cream/10">
              <img
                src={c.img}
                alt={c.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-display text-2xl text-cream mb-1">
                {c.name}
              </h3>
              <p class="font-sans text-[10px] tracking-[0.18em] uppercase text-gold">
                {c.role}
              </p>
            </div>
          </div>
          <p class="font-sans text-sm md:text-base text-cream/75 leading-relaxed">
            {c.bio}
          </p>
        </div>
      </dialog>
    ))
  }
</V2Layout>

<style>
  /* Chain graphic opacity — kept subtle so the headline reads first */
  .community-hero-chain {
    opacity: 0.18;
  }
</style>

<style is:global>
  /* Dialog backdrop matches the v2 dark aesthetic */
  .bio-dialog::backdrop {
    background-color: rgba(18, 8, 16, 0.75);
    backdrop-filter: blur(4px);
  }
</style>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>(
    "[data-bio-trigger]",
  );
  triggers.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-bio-trigger");
      const dialog = document.getElementById(
        `bio-${id}`,
      ) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  const dialogs = document.querySelectorAll<HTMLDialogElement>(".bio-dialog");
  dialogs.forEach((d) => {
    d.addEventListener("click", (e) => {
      if (e.target === d) d.close();
    });
    d.querySelector("[data-bio-close]")?.addEventListener("click", () =>
      d.close(),
    );
  });
</script>
