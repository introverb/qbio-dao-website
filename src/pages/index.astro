---
import V2Layout from "../components/v2/V2Layout.astro";
import V2Cta from "../components/v2/V2Cta.astro";
import EyebrowLabel from "../components/v2/EyebrowLabel.astro";
import QbiLogoMark from "../components/v2/QbiLogoMark.astro";
import { bentoCard, bentoHeading } from "../lib/v2-bg";

const substackPosts = [
  {
    title: "This Week in Quantum Biology (Jun 28–Jul 11)",
    date: "Jul 14, 2025",
    body: "Weekly digest covering developments in quantum biology, including the Quantum Biology Institute's protein research using MagLOV proteins and the DAO's work on field priorities and working group progress.",
    image:
      "https://substackcdn.com/image/fetch/$s_!VNvZ!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Ff4d26c2e-6d32-46ba-83cc-e884598f5248_1016x628.png",
    href: "https://quantumbiology.substack.com/p/this-week-in-quantum-biology-jun-49a",
  },
  {
    title: "This Week in Quantum Biology (Jun 21–27)",
    date: "Jun 30, 2025",
    body: "Weekly digest featuring the Quantum Biology Institute's new executive leadership and microscope construction progress, alongside the DAO's updated meeting schedule and new granting process development.",
    image:
      "https://substackcdn.com/image/fetch/$s_!ZE5i!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F6a56e1a3-6f07-4066-a18d-f136c2ed7be8_1179x664.png",
    href: "https://quantumbiology.substack.com/p/this-week-in-quantum-biology-jun-41d",
  },
  {
    title: "This Week in Quantum Biology (Jun 14–20)",
    date: "Jun 23, 2025",
    body: "Weekly update on the Institute's protein work with magnetosensitive proteins and the DAO's allocation of 500 ETH to support foundational quantum biology research.",
    image:
      "https://substackcdn.com/image/fetch/$s_!HFSv!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Ff6acfa3f-2323-4072-90d7-3beb53b89ee0_867x664.png",
    href: "https://quantumbiology.substack.com/p/this-week-in-quantum-biology-jun-56d",
  },
];

type Org = {
  name: string;
  eyebrow: string;
  body: string;
  accent: "gold" | "pink" | "teal";
  youAreHere: boolean;
  cta?: string;
  href?: string;
  external?: boolean;
  comingSoon?: boolean;
  vennDiagram?: boolean;
};

const orgs: Org[] = [
  {
    name: "Quantum Biology Ecosystem",
    eyebrow: "Synergy",
    body: "The Quantum Biology Ecosystem is a collective of 3 organizations synergistically building the quantum biology industry by design.",
    accent: "gold",
    youAreHere: false,
    vennDiagram: true,
  },
  {
    name: "Quantum Biology DAO",
    eyebrow: "Governance",
    body: "The Quantum Biology DAO accelerates the quantum biology field through community building, open governance, scientific experimentation, research grants, and IP development.",
    cta: "Join our Discord",
    href: "https://quantumbiology.community",
    external: true,
    accent: "pink",
    youAreHere: true,
  },
  {
    name: "Quantum Biology Institute",
    eyebrow: "Research",
    body: "The Quantum Biology Institute is a 501(c)(3) California non-profit that performs the basic research underpinning the field in an open-science fashion.",
    cta: "Visit Site",
    href: "https://quantumbiology.org",
    external: true,
    accent: "teal",
    youAreHere: false,
  },
  {
    name: "Quantum Biology Incubator",
    eyebrow: "Commercialization",
    body: "The QuantumBiology Incubator is a for-profit Delaware C-Corp that develops the technical workforce the industry needs while incubating the first batch of quantum biology startups.",
    accent: "gold",
    youAreHere: false,
    comingSoon: true,
  },
];

const accentTextClass = {
  gold: "text-gold",
  pink: "text-pink",
  teal: "text-teal",
} as const;

const accentItalicClass = {
  gold: "text-gold/90",
  pink: "text-pink/90",
  teal: "text-teal/90",
} as const;

const members = [
  {
    name: "Dr. Clarice D. Aiello",
    role: "Founder",
    img: "/images/team/clarice.jpeg",
    summary:
      "Quantum engineer exploring how quantum physics informs biology at the nanoscale.",
    bio: "Clarice is a quantum engineer interested in how quantum physics informs biology at the nanoscale. Born and raised in Brazil, Clarice obtained a Diplome d'Ingenieur in Physics from the Ecole Polytechnique in France and an M.Phil. in Physics from the University of Cambridge, Trinity College, in England; she received her Ph.D. from MIT in Electrical Engineering. She further held postdoctoral appointments in Bioengineering at Stanford, and in Chemistry at Berkeley.",
  },
  {
    name: "Dr. Geoff Anders",
    role: "Founder",
    img: "/images/team/geoff.jpeg",
    summary:
      "CEO of the Quantum Biology Institute and founder of Leverage, focused on supporting revolutionary scientific research.",
    bio: "Geoff Anders is the founder and CEO of Leverage, a research institute established in 2011 to support revolutionary scientific research. With a background in philosophy and social science, he leads Leverage's internal research and helps external research teams organize to make important scientific breakthroughs. His recent work focuses on the intersection of philosophy, science, and history, as it pertains especially to introspection, cognitive science, and artificial intelligence. Geoff is now the CEO of the Quantum Biology Institute and holds a PhD in Philosophy from Rutgers University and a BS in Economics from the Wharton School at the University of Pennsylvania.",
  },
  {
    name: "Dr. Alessandro Lodesani",
    role: "Founder",
    img: "/images/team/ale.jpeg",
    summary:
      "COO of the Quantum Biology Institute, designing innovative lab equipment and optimizing research operations.",
    bio: "Alessandro Lodesani is the Institute's Chief Operating Officer, overseeing its daily research operations. With a strong background in physics and engineering, combined with extensive experience in biology research, Alessandro focuses on designing innovative devices and optimizing lab processes. Originally from Italy, Alessandro earned a Bachelor's in Mechanical Engineering and a PhD in Physics, graduating with honors from the Polytechnic University of Milan, with a specialization in spintronics and molecular interfaces. His previous research at MIT focused on topological qubits and superconducting thin films, where he successfully developed the world's most efficient superconducting diode platform. Alessandro then joined the Institute in its early days at UCLA, where he led several projects investigating the influence of weak magnetic fields on biological systems.",
  },
  {
    name: "Jennilyn Gaitan",
    role: "Operations",
    img: "/images/team/jen.jpeg",
    summary:
      "Operations and administration lead for the Quantum Biology Institute, with two decades of experience refining systems and processes.",
    bio: "Jennilyn Gaitan graduated with a Bachelor of Science in Electronic Media and Film from Towson University. Since 2004, she has worked in various administrative and operational roles across multiple industries, including retail, higher education, photography, real estate, and small business operations. Jennilyn has a passion for creating and refining the systems and processes that businesses use, to run most efficiently, which has been a hallmark of her career. In November 2023, Jennilyn joined the Quantum Biology Institute, contributing her expertise to the administration and operations of the Institute.",
  },
  {
    name: "Kyra Gardner",
    role: "Media Director",
    img: "/images/team/kyra.jpeg",
    summary:
      "Communications Working Group Leader and co-founder of Smarter with Science, connecting complex topics to broader audiences.",
    bio: "Kyra Gardner is the Communications Working Group Leader for the Quantum Biology DAO, where she manages communications and social media. She joined the DAO in January of 2025 and carries out this work through Smarter with Science, a company she co-founded whose team members are also deeply involved in the quantum biology ecosystem. Despite not having as technical of a science background as some of her DAO peers, she enjoys finding ways to connect complex topics to everyday life and make them accessible to broader audiences.",
  },
];
---

<V2Layout
  title="Quantum Biology DAO"
  description="A global community advancing quantum biology research."
>
  <!-- ====================================================================== -->
  <!-- HERO  —  cube graphic anchored top-right, title on the left              -->
  <!-- ====================================================================== -->
  <section class="relative pb-16 md:pb-24">
    <!-- Cube graphic — enters from upper-right corner -->
    <div
      class="relative pt-20 lg:pt-0 lg:absolute lg:top-0 lg:right-0 lg:w-[55%] xl:w-[48%] lg:translate-x-[8%] pointer-events-none"
      style="opacity: 0.12;"
    >
      <img
        src="/images/graphics/cube-cutout.png"
        alt=""
        class="block w-full max-w-none"
        loading="eager"
      />
    </div>

    <!-- Title block on the left -->
    <div
      class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-8 lg:pt-32 z-10"
    >
      <div class="lg:max-w-[58%]">
        <EyebrowLabel accent="gold">Quantum Biology DAO</EyebrowLabel>
        <h1
          class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5rem] leading-[0.95] tracking-tight text-cream"
        >
          A global
          <em class="italic text-gold/90">community</em>
          <span class="block">
            advancing quantum biology research.
          </span>
        </h1>
        <p
          class="mt-8 font-sans text-[14px] text-cream/65 leading-relaxed max-w-md"
        >
          The Quantum Biology DAO accelerates the quantum biology field through
          community building, open governance, scientific experimentation,
          research grants, and IP development. Together we will understand biology
          at the quantum level. Check out our <a
            href="#"
            class="text-gold hover:text-pink-light underline underline-offset-2"
            >vision paper</a
          >.
        </p>
        <div class="mt-10 flex flex-col items-start gap-5">
          <V2Cta
            href="/qbio-token#how-to-buy"
            label="Get QBIO governance tokens"
            accent="gold"
          />
          <V2Cta
            href="https://quantumbiology.community"
            label="Join the community"
            accent="pink"
            external
          />
        </div>
      </div>
    </div>

  </section>

  <!-- ====================================================================== -->
  <!-- BENTO REGION                                                            -->
  <!-- ====================================================================== -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-6 lg:gap-7 auto-rows-auto">

      <!-- ============================================================= -->
      <!-- THE ECOSYSTEM (Org Map) — moved above Featured Grantee  TEAL   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <div class="mb-10">
          <EyebrowLabel accent="teal" class="mb-4">The ecosystem</EyebrowLabel>
          <h2 class={`${bentoHeading} max-w-3xl`}>
            Where we sit in the <em class="italic text-teal/90">quantum biology</em> world.
          </h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
          {
            orgs.map((org) => (
              <article class="flex flex-col rounded-lg border border-cream/10 bg-plum-deepest/40 p-6 md:p-7 relative">
                {org.youAreHere && (
                  <span
                    class="absolute inline-flex items-center px-3 py-1.5 rounded-full bg-pink text-plum-darkest font-sans text-[10px] font-bold tracking-[0.18em] uppercase whitespace-nowrap"
                    style="top: 0; left: 50%; transform: translate(-50%, -50%);"
                  >
                    You are here
                  </span>
                )}
                <p
                  class:list={[
                    "font-sans text-[10px] tracking-[0.25em] uppercase mb-4",
                    accentTextClass[org.accent],
                  ]}
                >
                  {org.eyebrow}
                </p>
                <h3 class="font-display text-xl md:text-2xl text-cream mb-4 leading-tight">
                  {org.name}
                </h3>
                <p class="font-sans text-[13px] text-cream/65 leading-relaxed mb-6 grow">
                  {org.body}
                </p>
                {org.cta && org.href && (
                  <V2Cta
                    href={org.href}
                    label={org.cta}
                    accent={org.accent}
                    external={org.external}
                    size="sm"
                  />
                )}
                {!org.cta && org.vennDiagram && (
                  <div aria-hidden="true" class="flex justify-center w-full">
                    <svg
                      viewBox="-2 -2 66 63"
                      width="66"
                      height="63"
                      fill="none"
                      stroke-width="1"
                    >
                      <circle cx="20" cy="20" r="20" stroke="#e5c46b" />
                      <circle cx="42" cy="20" r="20" stroke="#7dd3d3" />
                      <circle cx="31" cy="39" r="20" stroke="#d57db2" />
                    </svg>
                  </div>
                )}
                {!org.cta && org.comingSoon && (
                  <div
                    class="inline-flex items-center gap-3 font-sans text-[11px] tracking-[0.3em] uppercase text-gold/70 select-none"
                    aria-label="Coming soon"
                  >
                    <span
                      class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-gold/70"
                    >
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                    </span>
                    <span>Coming soon</span>
                  </div>
                )}
              </article>
            ))
          }
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- FEATURED GRANTEE                                       GOLD    -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
          <div class="lg:col-span-7">
            <EyebrowLabel accent="teal">Featured grantee</EyebrowLabel>
            <h2 class={`${bentoHeading} mb-6`}>
              The <em class="italic text-teal/90">Quantum Biology Institute</em>.
            </h2>
            <p
              class="font-sans text-[14px] text-cream/70 leading-relaxed max-w-2xl mb-10"
            >
              We engage researchers, crypto enthusiasts, industry experts, and
              the general public to accelerate the quantum biology revolution.
              Our flagship grant funds the Institute's experimental work
              probing quantum effects in living systems.
            </p>
            <div class="flex flex-col items-start gap-5">
              <V2Cta
                href="https://quantumbiology.org"
                label="The Institute"
                accent="teal"
                external
              />
              <V2Cta
                href="/science#granting"
                label="Granting process"
                accent="pink"
              />
            </div>
          </div>
          <div class="lg:col-span-5">
            <div
              class="aspect-square rounded-lg bg-teal/80 flex items-center justify-center p-10"
            >
              <div class="flex flex-col items-center text-center gap-4">
                <QbiLogoMark size={64} />
                <p
                  class="font-display text-lg md:text-xl text-plum-darkest leading-tight tracking-wider"
                >
                  QUANTUM<br />BIOLOGY<br />INSTITUTE
                </p>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- ECOSYSTEM UPDATES (Substack)                            PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
          <div>
            <EyebrowLabel accent="pink" class="mb-4">
              From the ecosystem
            </EyebrowLabel>
            <h2 class={bentoHeading}>
              Latest <em class="italic text-pink/90">updates</em>.
            </h2>
          </div>
          <V2Cta
            href="https://quantumbiology.substack.com/"
            label="Read the digest"
            accent="pink"
            external
          />
        </div>
        <div class="grid md:grid-cols-3 gap-5 md:gap-6">
          {
            substackPosts.map((p) => (
              <a
                href={p.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col rounded-lg border border-cream/10 overflow-hidden hover:border-pink/40 transition-colors bg-plum-deepest/40"
              >
                <div class="aspect-[16/10] overflow-hidden bg-plum-deepest">
                  <img
                    src={p.image}
                    alt=""
                    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                    loading="lazy"
                  />
                </div>
                <div class="p-5 md:p-6 flex flex-col grow">
                  <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-pink/70 mb-3">
                    {p.date}
                  </p>
                  <h3 class="font-display text-base md:text-lg text-cream mb-3 leading-snug group-hover:text-pink-light transition-colors">
                    {p.title}
                  </h3>
                  <p class="font-sans text-[12px] text-cream/60 leading-relaxed grow">
                    {p.body}
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- TEAM                                                    GOLD   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <div class="mb-10">
          <EyebrowLabel accent="gold" class="mb-4">Meet the team</EyebrowLabel>
          <h2 class={bentoHeading}>
            The people <em class="italic text-gold/90">behind</em> the DAO.
          </h2>
        </div>
        <div
          class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-6 gap-y-10"
        >
          {
            members.map((person, i) => (
              <button
                type="button"
                data-bio-trigger={`home-${i}`}
                class="group flex flex-col items-center text-center p-4 -m-4 rounded-2xl bg-transparent hover:bg-pink/10 transition-colors cursor-pointer outline-none appearance-none border-0 focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-plum-darkest"
                aria-haspopup="dialog"
                aria-controls={`bio-home-${i}`}
              >
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden bg-plum-deepest mb-4 ring-1 ring-cream/10 group-hover:ring-gold transition">
                  <img
                    src={person.img}
                    alt={person.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="font-sans font-semibold text-sm text-cream mb-1">
                  {person.name}
                </h3>
                <p class="font-sans text-[10px] uppercase tracking-[0.18em] text-gold mb-3">
                  {person.role}
                </p>
                <p class="font-sans text-[11px] text-cream/55 leading-relaxed">
                  {person.summary}
                </p>
                <span class="mt-2 font-sans text-[10px] tracking-[0.18em] uppercase text-gold/70 group-hover:text-pink-light transition-colors">
                  Read bio →
                </span>
              </button>
            ))
          }
        </div>
      </article>
    </div>
  </div>

  <!-- ====================================================================== -->
  <!-- QUESTIONS CTA                                                          -->
  <!-- ====================================================================== -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <EyebrowLabel accent="gold" class="mb-8">Questions</EyebrowLabel>
      <h2
        class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.05] tracking-tight text-cream mb-10"
      >
        Still have <em class="italic text-gold/90">questions</em>?
      </h2>
      <div class="inline-flex">
        <V2Cta href="/faqs" label="See all FAQs" accent="gold" />
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- Bio dialogs (modal popups, one per team member)                        -->
  <!-- ====================================================================== -->
  {
    members.map((person, i) => (
      <dialog
        id={`bio-home-${i}`}
        class="bio-dialog p-0 rounded-lg bg-plum-darkest text-cream max-w-2xl w-[92vw] m-auto border border-cream/10"
      >
        <div class="relative p-8 md:p-10">
          <button
            type="button"
            data-bio-close
            aria-label="Close"
            class="absolute top-4 right-4 p-2 rounded-full text-cream/50 hover:text-cream hover:bg-cream/5 transition-colors"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
          <div class="flex flex-col sm:flex-row sm:items-center gap-5 mb-6 pr-8">
            <div class="w-20 h-20 shrink-0 rounded-full overflow-hidden bg-plum-deepest ring-1 ring-cream/10">
              <img
                src={person.img}
                alt={person.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-display text-2xl text-cream mb-1">
                {person.name}
              </h3>
              <p class="font-sans text-[10px] tracking-[0.18em] uppercase text-gold">
                {person.role}
              </p>
            </div>
          </div>
          <p class="font-sans text-sm md:text-base text-cream/75 leading-relaxed">
            {person.bio}
          </p>
        </div>
      </dialog>
    ))
  }
</V2Layout>

<style is:global>
  /* Dialog backdrop for v2 (dark, blurred to match aesthetic) */
  .bio-dialog::backdrop {
    background-color: rgba(18, 8, 16, 0.75);
    backdrop-filter: blur(4px);
  }
</style>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>(
    "[data-bio-trigger]",
  );
  triggers.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-bio-trigger");
      const dialog = document.getElementById(
        `bio-${id}`,
      ) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  const dialogs = document.querySelectorAll<HTMLDialogElement>(".bio-dialog");
  dialogs.forEach((d) => {
    d.addEventListener("click", (e) => {
      if (e.target === d) d.close();
    });
    d.querySelector("[data-bio-close]")?.addEventListener("click", () =>
      d.close(),
    );
  });
</script>
