---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Quantum Biology DAO">
  <main class="min-h-screen flex items-center justify-center px-6 py-24 bg-plum-darkest text-cream">
    <div class="max-w-2xl text-center">
      <p class="font-sans text-sm tracking-[0.2em] uppercase text-pink mb-6">
        Coming Soon
      </p>
      <h1 class="font-display text-5xl md:text-6xl leading-tight mb-6">
        A global community advancing quantum biology research.
      </h1>
      <p class="font-sans text-base md:text-lg text-cream/70 max-w-xl mx-auto">
        Building in public. The full Quantum Biology DAO homepage is on its way.
      </p>
    </div>
  </main>
</Layout>
