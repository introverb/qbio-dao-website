---
import V2Layout from "../components/v2/V2Layout.astro";
import V2Cta from "../components/v2/V2Cta.astro";
import EyebrowLabel from "../components/v2/EyebrowLabel.astro";
import { bentoCard, bentoHeading } from "../lib/v2-bg";

const explainerUrl =
  "https://docs.google.com/document/d/1Eoye_Ltl_DybiZX59V87T3SO1Yx46St9_IBPGBFoSloY/edit?tab=t.0";

type Block =
  | { kind: "p"; text: string }
  | { kind: "ul"; items: string[] };

interface FAQ {
  question: string;
  body: Block[];
}

const faqs: FAQ[] = [
  {
    question: "What is a DAO",
    body: [
      {
        kind: "p",
        text: 'The word "DAO" means "decentralized autonomous organization." A DAO harnesses the collective efforts of many groups of contributors to expedite the development of innovations and new technologies. By using blockchain, our community can govern itself fairly and transparently, while also engaging a diverse and global pool of talent and contribution. Science DAOs fund and incubate projects from the initial stages of research. They stand out as community-owned and -operated entities.',
      },
    ],
  },
  {
    question: "Why should I get involved?",
    body: [
      {
        kind: "p",
        text: "To advance the field of quantum biology! By participating in the quantum biology DAO, you not only accelerate a new field of science, but earn the right to direct and govern our collective—shaping the arc of this new field.",
      },
    ],
  },
  {
    question: "Why does quantum biology matter?",
    body: [
      {
        kind: "p",
        text: "Quantum biology unlocks a fundamentally new way to actuate on biology. Check out how quantum biology overlaps with a wide array of fields in our briefs.",
      },
    ],
  },
  {
    question: "How can I get involved?",
    body: [
      {
        kind: "p",
        text: "We are excited to bring on new researchers to perform key experiments, community members to discuss the latest developments and suggest new avenues, advocates interested in spreading the word, and enthusiasts to direct our pool of resources into the most important research.",
      },
    ],
  },
  {
    question:
      "Who can join the DAO? Do I need to be a scientist to participate?",
    body: [
      {
        kind: "p",
        text: "Anyone can join the Quantum Biology DAO. You do not need to be a scientist to participate. The DAO brings together researchers, creatives, engineers, builders, writers, funders, organizers, and curious community members who want to help advance the field. Scientific expertise is essential to our mission, but progress also depends on governance, funding decisions, communications, education, and community coordination. Different contributors add value in different ways.",
      },
    ],
  },
  {
    question: "What is the Quantum Biology Ecosystem?",
    body: [
      {
        kind: "p",
        text: "The Quantum Biology Ecosystem is a coordinated group of organizations working together to advance quantum biology from basic science to real-world impact.",
      },
      { kind: "p", text: "It includes:" },
      {
        kind: "ul",
        items: [
          "The Quantum Biology Institute, a nonprofit focused on foundational, open scientific research",
          "The Quantum Biology DAO (us!), a decentralized community that funds research, governs priorities, and supports translation and education",
          "The Quantum Biology Incubator (to be launched), which helps develop talent and early-stage ventures emerging from the field",
        ],
      },
      {
        kind: "p",
        text: "Together, these entities align incentives across research, funding, governance, and commercialization to accelerate the development of quantum biology as a scientific field and future industry.",
      },
    ],
  },
  {
    question: "What is quantum biology?",
    body: [
      {
        kind: "p",
        text: 'Quantum biology is an emerging scientific field which asks: "How does life depend on quantum phenomena?" Working at the intersection of quantum physics and biology, the field studies how quantum phenomena, which are tiny and ubiquitous, impact biological systems, including the development and functioning of the human body. These quantum phenomena include electron spin superpositions, noise-assisted tunneling, and more.',
      },
    ],
  },
  {
    question: "Why is quantum biology important?",
    body: [
      {
        kind: "p",
        text: "Physics has produced extensive knowledge of the universe on a fundamental level. Biology, however, remains, to an important extent, a mystery. Quantum biology is building a bridge between the fields, making it possible to explain phenomena that have never been explained before, like the biological effects of weak magnetic fields. Understanding how quantum phenomena shape the life of the cell will unlock a new level of biological understanding, which may yield many applications in health, biomanufacturing, and beyond.",
      },
    ],
  },
  {
    question: "How does classical biology compare to quantum biology?",
    body: [
      {
        kind: "p",
        text: "Classical biology studies life under the assumption that matter behaves classically, that is, as described by the physical laws of Newton and electromagnetic laws of Maxwell. Quantum biology adds the equations developed by Schrödinger and Dirac, which yield different predictions about the behavior of atoms, molecules, weak magnetic fields, and more.",
      },
    ],
  },
  {
    question: "How can I help advance the quantum biology community?",
    body: [
      {
        kind: "p",
        text: "We are excited to bring on new researchers to perform key experiments, community members to discuss the latest developments and suggest new avenues, advocates interested in spreading the word, and enthusiasts to direct our pool of resources into the most important research.",
      },
    ],
  },
];
---

<V2Layout
  title="FAQs — Quantum Biology DAO"
  description="Frequently asked questions about the Quantum Biology DAO — what we do, how governance works, and how you can get involved."
>
  <!-- ====================================================================== -->
  <!-- HERO  —  molecules graphic anchored top-right, title on the left       -->
  <!-- ====================================================================== -->
  <section class="relative pb-16 md:pb-24">
    <!-- Molecules graphic — branching network feels appropriate for FAQs -->
    <div
      class="relative pt-20 lg:pt-0 lg:absolute lg:top-0 lg:right-0 lg:w-[55%] xl:w-[48%] pointer-events-none faqs-hero-molecules"
    >
      <img
        src="/images/graphics/molecules.png"
        alt=""
        class="block w-full max-w-none"
        loading="eager"
      />
    </div>

    <!-- Title block -->
    <div
      class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-8 lg:pt-32 z-10"
    >
      <div class="lg:max-w-[58%]">
        <EyebrowLabel accent="gold">FAQs</EyebrowLabel>
        <h1
          class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5rem] leading-[0.95] tracking-tight text-cream"
        >
          Frequently
          <em class="italic text-gold/90">asked</em>
          <span class="block">questions.</span>
        </h1>
        <p
          class="mt-8 font-sans text-[14px] text-cream/65 leading-relaxed max-w-md"
        >
          Your guide to how our decentralized science community works — what
          quantum biology is, how our DAO funds and governs research, and how
          you can get involved. Whether you're coming from the science, the
          crypto space, or somewhere in between, this guide walks you through
          the core ideas.
        </p>
        <div class="mt-10 flex flex-col items-start gap-5">
          <V2Cta
            href={explainerUrl}
            label="Read the full explainer"
            accent="gold"
            external
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- BENTO REGION                                                            -->
  <!-- ====================================================================== -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-6 lg:gap-7 auto-rows-auto">

      <!-- ============================================================= -->
      <!-- ABOUT — short intro setting context for the FAQ list    PINK   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="pink">In brief</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-8 max-w-3xl`}>
          What we do, and <em class="italic text-pink/90">why</em>.
        </h2>
        <div
          class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4 max-w-3xl"
        >
          <p>
            Quantum Biology DAO exists to fund and coordinate open research
            into quantum biology — a field that explores how quantum phenomena
            like spin, superposition, or tunneling might influence living
            systems. We believe the next breakthroughs in biology won't come
            from behind closed doors, but from open collaboration of
            scientists, engineers, and curious people around the world.
          </p>
          <p>
            The DAO is part of a broader ecosystem that also includes the
            Quantum Biology Institute, a physical lab where experiments are
            being built, and the Quantum Biology Incubator, which supports
            early-stage ideas and tools.
          </p>
          <p>
            Below, you'll find answers to the most frequently asked questions
            about our governance model, the science behind our mission, and
            the roadmap ahead. If something's missing or unclear, reach out on
            Discord. We're building this DAO in public.
          </p>
        </div>
      </article>

      <!-- ============================================================= -->
      <!-- THE FAQ ACCORDION                                       TEAL   -->
      <!-- ============================================================= -->
      <article class={`${bentoCard} lg:col-span-12`}>
        <EyebrowLabel accent="teal">Questions</EyebrowLabel>
        <h2 class={`${bentoHeading} mb-10`}>
          The most <em class="italic text-teal/90">asked</em>.
        </h2>
        <div class="space-y-3 max-w-4xl">
          {
            faqs.map((f) => (
              <details class="faq-item-v2 group rounded-lg bg-plum-deepest/40 border border-cream/10 overflow-hidden transition-colors hover:border-teal/40">
                <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between gap-4 font-display text-base md:text-lg text-cream">
                  <span>{f.question}</span>
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="shrink-0 text-teal transition-transform duration-200 group-open:rotate-180"
                    aria-hidden="true"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </summary>
                <div class="px-6 pb-6 pt-1 font-sans text-[14px] text-cream/70 leading-relaxed space-y-3">
                  {f.body.map((block) =>
                    block.kind === "p" ? (
                      <p>{block.text}</p>
                    ) : (
                      <ul class="list-disc pl-6 space-y-1.5 marker:text-teal/60">
                        {block.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    ),
                  )}
                </div>
              </details>
            ))
          }
        </div>
      </article>
    </div>
  </div>

  <!-- ====================================================================== -->
  <!-- STILL HAVE QUESTIONS — Discord CTA replaces the "see all FAQs" link    -->
  <!-- ====================================================================== -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <EyebrowLabel accent="pink" class="mb-8">Still curious</EyebrowLabel>
      <h2
        class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.05] tracking-tight text-cream mb-10"
      >
        Reach out on <em class="italic text-pink/90">Discord</em>.
      </h2>
      <div class="inline-flex">
        <V2Cta
          href="https://quantumbiology.community"
          label="Join the Discord"
          accent="pink"
          external
        />
      </div>
    </div>
  </section>
</V2Layout>

<style>
  /* Subtle molecules graphic in the hero — branching network as a metaphor
     for "questions branch out from one another". */
  .faqs-hero-molecules {
    opacity: 0.15;
  }
</style>

<!-- ::marker / ::-webkit-details-marker pseudo-elements need is:global on
     Astro because the scoped class hash doesn't apply correctly to
     browser-rendered pseudo-elements. -->
<style is:global>
  details.faq-item-v2 > summary::-webkit-details-marker {
    display: none;
  }
  details.faq-item-v2 > summary::marker {
    content: "";
  }
</style>
