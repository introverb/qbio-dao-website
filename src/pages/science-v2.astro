---
import sharp from "sharp";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import QbiLogoMark from "../components/v2/QbiLogoMark.astro";

const examples = [
  { label: "Photosynthesis" },
  { label: "Bird navigation" },
  { label: "DNA repair" },
  { label: "Magnetic sensitivity" },
  { label: "Sense of smell" },
];

const foundations = [
  { label: "FAQ", href: "/faqs", external: false },
  { label: "Vision paper", href: "#", external: false },
  { label: "Briefs", href: "#", external: false },
  { label: "QBI study — tadpole", href: "#", external: false },
  {
    label: "PMC: Quantum biology review",
    href: "https://pmc.ncbi.nlm.nih.gov/articles/PMC6304024/",
    external: true,
  },
  {
    label: "SciAm: Bird navigation",
    href: "https://www.scientificamerican.com/article/how-migrating-birds-use-quantum-effects-to-navigate/",
    external: true,
  },
  { label: "TBD", href: "#", external: false },
  { label: "TBD", href: "#", external: false },
];

const testimonials = [
  {
    quote:
      "There is a quantum biology sized hole in biological science that the DAO is needed for - until quantum biology is taught in high school biology classes, it will continue to be needed.",
    author: "Chris Rourk",
    role: "Science Working Group Leader",
  },
  {
    quote:
      "The research we're supporting isn't abstract, it's about unlocking discoveries that impact life itself. Advancing quantum biology through grants ensures ideas with potential don't stay trapped in theory, and the granting process here feels transparent, mission-driven, and built to accelerate breakthroughs.",
    author: "Zicjoe",
    role: "DAO Community Member",
  },
];

// Tighter padding for the bento panels — they're narrower than the hero card
const bentoCard =
  "relative bg-plum-darkest rounded-lg p-8 md:p-10 lg:p-12 h-full";
const bentoHeading =
  "font-display text-3xl md:text-4xl leading-[1.05] tracking-tight text-cream";
const labelBase = "font-sans text-[11px] tracking-[0.3em] uppercase mb-8";

// Tileable sine-wave overlay — gives a subtle wave-interference texture
// behind the dot grid. Each wave's period divides the tile width evenly so
// the pattern seams cleanly when tiled.
const WAVE_TILE_W = 600;
const WAVE_TILE_H = 360;
const _waves = [
  { y: 60, amp: 18, period: 300, phase: 0 },
  { y: 140, amp: 24, period: 600, phase: 1.05 },
  { y: 220, amp: 14, period: 200, phase: 2.5 },
  { y: 300, amp: 26, period: 600, phase: 4.4 },
];
const _wavePaths = _waves
  .map(({ y, amp, period, phase }) => {
    let d = `M0,${y}`;
    for (let x = 8; x <= WAVE_TILE_W; x += 8) {
      const wy = y + Math.sin((x / period) * Math.PI * 2 + phase) * amp;
      d += ` L${x},${wy.toFixed(1)}`;
    }
    return `<path d="${d}" stroke="#eee8df" stroke-width="0.6" fill="none"/>`;
  })
  .join("");
const _waveSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="${WAVE_TILE_W}" height="${WAVE_TILE_H}">${_wavePaths}</svg>`;
const waveBg = `url("data:image/svg+xml;utf8,${encodeURIComponent(_waveSvg)}")`;

// "Cube-style" neuron — densely packed clusters of mixed mechanical
// shapes (small circles, squares, short horizontal and vertical traces)
// sampled from the neuron PNG at build time. Each shape's size is mapped
// from pixel alpha so the silhouette holds together while reading as a
// circuit/machine-tissue weave rather than a uniform halftone.
const NEURON_SAMPLE_STEP = 5; // tighter sampling → much denser
const NEURON_ALPHA_THRESHOLD = 20;
const _neuronImg = await sharp("public/images/graphics/neuron.png")
  .ensureAlpha()
  .raw()
  .toBuffer({ resolveWithObject: true });
const _NW = _neuronImg.info.width;
const _NH = _neuronImg.info.height;
const _NCH = _neuronImg.info.channels;
const _neuronShapes: string[] = [];
for (let y = 0; y < _NH; y += NEURON_SAMPLE_STEP) {
  for (let x = 0; x < _NW; x += NEURON_SAMPLE_STEP) {
    const idx = (y * _NW + x) * _NCH;
    const a = _neuronImg.data[idx + 3];
    if (a < NEURON_ALPHA_THRESHOLD) continue;

    // Intensity 0..1 from alpha
    const t = (a - NEURON_ALPHA_THRESHOLD) /
      (255 - NEURON_ALPHA_THRESHOLD);

    // Deterministic shape roll based on position so it stays stable
    // across rebuilds and the pattern feels organic rather than
    // perfectly grid-aligned.
    const roll = ((x * 7919 + y * 1009 + 31) % 100) / 100;

    let shape: string;
    if (roll < 0.55) {
      // Dominant: small circles, size scales with intensity
      const r = (0.4 + t * 2.6).toFixed(2);
      shape = `<circle cx="${x}" cy="${y}" r="${r}"/>`;
    } else if (roll < 0.74) {
      // Tiny solid squares
      const s = 1.0 + t * 2.3;
      const half = (s / 2).toFixed(2);
      shape = `<rect x="${(x - s / 2).toFixed(2)}" y="${(y - s / 2).toFixed(2)}" width="${s.toFixed(2)}" height="${s.toFixed(2)}"/>`;
    } else if (roll < 0.88) {
      // Short horizontal traces (circuit feel)
      const w = 3 + t * 4.5;
      const h = 0.9;
      shape = `<rect x="${(x - w / 2).toFixed(2)}" y="${(y - h / 2).toFixed(2)}" width="${w.toFixed(2)}" height="${h.toFixed(2)}"/>`;
    } else {
      // Short vertical traces
      const w = 0.9;
      const h = 3 + t * 4.5;
      shape = `<rect x="${(x - w / 2).toFixed(2)}" y="${(y - h / 2).toFixed(2)}" width="${w.toFixed(2)}" height="${h.toFixed(2)}"/>`;
    }
    _neuronShapes.push(shape);
  }
}
const neuronDotsSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${_NW} ${_NH}" preserveAspectRatio="xMidYMid meet" width="100%" height="auto" fill="#7dd3d3" aria-hidden="true">${_neuronShapes.join("")}</svg>`;
---

<Layout
  title="Science — Quantum Biology DAO"
  description="Learn what quantum biology is and how we're building a new, decentralized process to fund its most important experiments."
>
  <Header />
  <main
    class="bg-plum-deepest text-cream relative overflow-hidden"
  >
    <!-- Bg layer 1: tileable sine waves (wave-interference reference) -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.06]"
      style={`background-image: ${waveBg}; background-size: ${WAVE_TILE_W}px ${WAVE_TILE_H}px;`}
      aria-hidden="true"
    >
    </div>
    <!-- Bg layer 2: subtle dot grid on top -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle, #eee8df 1px, transparent 1px); background-size: 22px 22px;"
      aria-hidden="true"
    >
    </div>

    <!-- ==================================================================== -->
    <!-- 01 — HERO  (neuron anchored top-right of page, text on the left)     -->
    <!-- ==================================================================== -->
    <section class="relative pb-16 md:pb-24">
      <!-- Neuron — anchored to very top-right of the page, bleeding right.
           On mobile it stacks above the text; on lg+ it goes absolute. -->
      <div
        class="relative pt-20 lg:pt-0 lg:absolute lg:top-0 lg:right-0 lg:w-[77%] xl:w-[70%] lg:translate-x-[10%] pointer-events-none opacity-[0.17] [&_svg]:block [&_svg]:w-full [&_svg]:max-w-none"
        set:html={neuronDotsSvg}
        aria-label="Branching neuron rendered as a field of dots"
      >
      </div>

      <!-- Text on the left side -->
      <div
        class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-8 lg:pt-32 z-10"
      >
        <div class="lg:max-w-[52%]">
          <p class={`${labelBase} text-gold`}>Science</p>
          <h1
            class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5rem] leading-[0.95] tracking-tight text-cream"
          >
            The science
            <span class="block">
              <em class="font-display italic text-gold/90">&amp;</em> the system.
            </span>
          </h1>
          <p
            class="mt-8 font-sans text-[14px] text-cream/65 leading-relaxed max-w-md"
          >
            Learn what quantum biology is and how we're building a new,
            decentralized process to fund its most important experiments.
          </p>
          <a
            href="https://quantumbiology.community"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-10 inline-flex items-center gap-3 font-sans text-[11px] tracking-[0.3em] uppercase text-gold hover:text-pink-light transition-colors group"
          >
            <span
              class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gold text-plum-darkest group-hover:bg-pink-light transition-colors"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><polyline points="12 5 19 12 12 19"
                ></polyline></svg
              >
            </span>
            <span>Join the working group</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ==================================================================== -->
    <!-- BENTO REGION — interlocking panels after the hero                    -->
    <!-- ==================================================================== -->
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pb-16 md:pb-24">
      <div class="grid lg:grid-cols-12 gap-6 lg:gap-7 auto-rows-auto">

        <!-- ============================================================ -->
        <!-- FOUNDATIONS                                            PINK   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-7`}>
          <p class={`${labelBase} text-pink`}>Foundations</p>
          <h2 class={`${bentoHeading} mb-6`}>
            What is <em class="italic text-pink/90">quantum</em> biology.
          </h2>
          <div
            class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              Quantum biology is an emerging scientific field that explores
              how life depends on quantum phenomena.
            </p>
            <p>
              At its core, it studies how superposition, electron spin,
              entanglement, and quantum tunneling can influence the molecules,
              cells, and systems of living organisms.
            </p>
            <p>
              While quantum effects are well-documented in physics and
              chemistry, biology has long been treated as "too messy" or "too
              warm" for these delicate phenomena. But this assumption is
              breaking down.
            </p>
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- HISTORY                                                GOLD   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-5`}>
          <p class={`${labelBase} text-gold`}>History</p>
          <h2 class={`${bentoHeading} mb-6`}>
            A brief <em class="italic text-gold/90">history</em>.
          </h2>
          <div
            class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              Erwin Schrödinger, one of the fathers of quantum theory, wrote
              "What is Life?" in 1944 — postulating the need for quantum
              mechanics to explain heredity, prior to the discovery of DNA.
            </p>
            <p>
              In the 1960s and 70s, researchers began finding examples of
              natural phenomena (tunneling in enzymes, bird navigation) that
              depended on quantum effects.
            </p>
            <p>
              Now, researchers are aiming to construct new instruments to
              directly probe quantum states and help unlock the quantum
              secrets of life.
            </p>
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- IN THE WILD — popular examples strip                   PINK   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-12 lg:p-10`}>
          <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
            <div>
              <p class={`${labelBase} text-pink mb-2`}>In the wild</p>
              <h3
                class="font-display text-2xl md:text-3xl text-cream tracking-tight"
              >
                Popular <em class="italic text-pink/90">examples</em>.
              </h3>
            </div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
            {
              examples.map((ex, i) => (
                <div class="border border-cream/10 rounded-lg aspect-[4/3] flex flex-col items-center justify-end p-4">
                  <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-pink/60 mb-1">
                    {String(i + 1).padStart(2, "0")}
                  </p>
                  <p class="font-display text-base text-cream text-center leading-tight">
                    {ex.label}
                  </p>
                </div>
              ))
            }
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- 04 — RESOURCES                                         GOLD   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-5`}>
          <p class={`${labelBase} text-gold`}>Further reading</p>
          <h2 class={`${bentoHeading} mb-8`}>
            Explore the <em class="italic text-gold/90">foundations</em>.
          </h2>
          <div class="grid grid-cols-2 gap-2">
            {
              foundations.map((f) => (
                <a
                  href={f.href}
                  target={f.external ? "_blank" : undefined}
                  rel={f.external ? "noopener noreferrer" : undefined}
                  class="group flex items-start justify-between gap-2 rounded-md border border-cream/10 hover:border-gold/40 hover:bg-mauve/15 transition-colors px-3 py-3"
                >
                  <span class="font-sans text-[12px] text-cream/85 leading-snug">
                    {f.label}
                  </span>
                  <svg
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-gold opacity-60 group-hover:opacity-100 shrink-0 mt-0.5"
                    aria-hidden="true"
                  >
                    {f.external ? (
                      <>
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </>
                    ) : (
                      <>
                        <path d="M5 12h14" />
                        <polyline points="12 5 19 12 12 19" />
                      </>
                    )}
                  </svg>
                </a>
              ))
            }
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- 05 — OUR FOCUS                                         TEAL   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-7`}>
          <p class={`${labelBase} text-teal`}>Our focus</p>
          <h2 class={`${bentoHeading} mb-6`}>
            What kind of <em class="italic text-teal/90">quantum biology</em>
            are we interested in?
          </h2>
          <div
            class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4"
          >
            <p>
              There are many "flavors" of quantum biology — from birds
              navigating magnetic fields, to quantum coherence in
              photosynthesis, to theories of consciousness in microtubules.
            </p>
            <p>
              At the Quantum Biology DAO, we're especially focused on
              experimentally testable quantum effects with real-world
              relevance and clear theoretical grounding.
            </p>
            <p>
              So far, we've been particularly interested in two areas:
              <span class="text-teal">low-field magnetic effects</span>
              and <span class="text-teal">the radical pair mechanism</span>.
              These make specific predictions and could explain phenomena
              from tadpole development to human fertility.
            </p>
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- 06 — INSTITUTE                                         TEAL   -->
        <!-- ============================================================ -->
        <article
          class={`${bentoCard} lg:col-span-7 lg:p-10`}
                 >
          <p class={`${labelBase} text-teal`}>Flagship grant</p>
          <div class="grid sm:grid-cols-[1fr_1.1fr] gap-6 items-center">
            <div
              class="aspect-square bg-teal/80 rounded-lg flex items-center justify-center p-6"
            >
              <div class="flex flex-col items-center text-center gap-3">
                <QbiLogoMark size={56} />
                <p
                  class="font-display text-base md:text-lg text-plum-darkest leading-tight tracking-wider"
                >
                  QUANTUM<br />BIOLOGY<br />INSTITUTE
                </p>
              </div>
            </div>
            <div>
              <h2
                class="font-display text-2xl md:text-3xl leading-[1.1] tracking-tight text-cream mb-4"
              >
                The Quantum Biology
                <em class="italic text-teal/90">Institute</em>.
              </h2>
              <div
                class="font-sans text-[13px] text-cream/70 leading-relaxed space-y-3"
              >
                <p>
                  We made the largest grant ever awarded in quantum biology
                  to the Quantum Biology Institute — a nonprofit lab in Los
                  Angeles funding real scientists doing real experiments.
                </p>
                <p>
                  The Institute is building a quantum microscope to detect
                  electron spin states inside live cells.
                </p>
              </div>
            </div>
          </div>
        </article>

        <!-- ============================================================ -->
        <!-- 07 — FUNDING                                           PINK   -->
        <!-- ============================================================ -->
        <article
          id="granting"
          class={`${bentoCard} lg:col-span-5 flex flex-col`}
                 >
          <p class={`${labelBase} text-pink`}>Funding</p>
          <h2 class={`${bentoHeading} mb-6`}>
            The granting <em class="italic text-pink/90">process</em>.
          </h2>
          <div
            class="font-sans text-[14px] text-cream/70 leading-relaxed space-y-4 mb-8 flex-grow"
          >
            <p>
              We're building a new way to fund quantum biology — one that's
              community-driven, transparent, and designed to support
              experiments that matter.
            </p>
            <p>
              The full granting process is still in development. If you have
              ideas:
            </p>
          </div>
          <a
            href="https://quantumbiology.community"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 font-sans text-[11px] tracking-[0.3em] uppercase text-pink hover:text-pink-light transition-colors group self-start"
          >
            <span
              class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-pink text-plum-darkest group-hover:bg-pink-light transition-colors"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><polyline points="12 5 19 12 12 19"
                ></polyline></svg
              >
            </span>
            <span>Visit our Discord</span>
          </a>
        </article>

        <!-- ============================================================ -->
        <!-- 08 — VOICES                                            PINK   -->
        <!-- ============================================================ -->
        <article class={`${bentoCard} lg:col-span-12`}>
          <p class={`${labelBase} text-pink`}>Voices</p>
          <h2 class={`${bentoHeading} mb-8`}>
            From the <em class="italic text-pink/90">working group</em>.
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            {
              testimonials.map((t) => (
                <div class="border border-cream/10 rounded-lg p-6 md:p-8 flex flex-col">
                  <svg
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="text-pink/60 mb-5"
                    aria-hidden="true"
                  >
                    <path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z" />
                  </svg>
                  <p class="font-display text-lg md:text-xl text-cream/90 leading-snug mb-6 flex-grow">
                    {t.quote}
                  </p>
                  <div class="border-t border-cream/10 pt-4">
                    <p class="font-sans text-cream font-semibold text-sm">
                      {t.author}
                    </p>
                    <p class="font-sans text-cream/50 text-xs mt-1 tracking-wide uppercase">
                      {t.role}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </div>

    <!-- ==================================================================== -->
    <!-- 09 — QUESTIONS                                             GOLD       -->
    <!-- ==================================================================== -->
    <section class="relative py-20 md:py-28">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <p class={`${labelBase} text-gold`}>Questions</p>
        <h2
          class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.05] tracking-tight text-cream mb-10"
        >
          Still have <em class="italic text-gold/90">questions</em>?
        </h2>
        <a
          href="/faqs-v2"
          class="inline-flex items-center gap-3 font-sans text-[11px] tracking-[0.3em] uppercase text-gold hover:text-pink-light transition-colors group"
        >
          <span
            class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gold text-plum-darkest group-hover:bg-pink-light transition-colors"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M5 12h14"></path><polyline points="12 5 19 12 12 19"
              ></polyline></svg
            >
          </span>
          <span>See all FAQs</span>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<!-- Drop the dark bg baked into the header logo PNG on this page only.
     Lighten keeps the brighter of (logo pixel, page bg) per-pixel, so the
     near-black logo bg falls away on plum-deepest while the cream glyph
     stays visible. (Long-term fix: re-export the PNG with proper alpha.) -->
<style is:global>
  header img[alt=""] {
    mix-blend-mode: lighten;
  }
</style>
